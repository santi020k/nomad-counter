---
import LoginCardIsland from './LoginCard'
---

<section class="hero" data-animate>
  <div>
    <p class="eyebrow" data-i18n="heroEyebrow">Counting your days</p>
    <h1 data-i18n="heroTitle">Know your days before they count against you.</h1>
    <p data-i18n="heroLead">
      Log stays by country, count inclusive calendar days, and see when a common residency threshold deserves a closer look.
    </p>
    <div class="hero-actions">
      <a class="btn" href="#counter" data-i18n="heroActionPrimary">Start counting</a>
      <a class="btn secondary" href="#faq" data-i18n="heroActionSecondary">How it works</a>
    </div>
    <dl class="hero-facts" aria-label="Nomad Counter highlights" data-i18n-aria-label="heroFactsLabel">
      <div>
        <dt data-i18n="heroFact1Label">Default threshold</dt>
        <dd data-i18n="heroFact1Value">183 days</dd>
      </div>
      <div>
        <dt data-i18n="heroFact2Label">Counting rule</dt>
        <dd data-i18n="heroFact2Value">Entry and exit count</dd>
      </div>
      <div>
        <dt data-i18n="heroFact3Label">Privacy model</dt>
        <dd data-i18n="heroFact3Value">Local until sync</dd>
      </div>
    </dl>
  </div>
  <LoginCardIsland client:load />
</section>

<style is:global>
/* ── Shell ──────────────────────────────── */
  .app-shell {
    padding-block: clamp(12px, 2vw, 28px) 32px;
  }

  /* ── Hero ───────────────────────────────── */
  .hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 400px);
    gap: clamp(22px, 5vw, 56px);
    align-items: start;
    padding-block: clamp(16px, 3vh, 40px) clamp(24px, 4vh, 56px);
    isolation: isolate;
  }

  .hero::before,
  .hero::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: -1;
  }

  .hero::before {
    width: 480px;
    height: 480px;
    top: -180px;
    right: -140px;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent-soft) 22%, transparent), transparent 65%);
  }

  .hero::after {
    width: 260px;
    height: 260px;
    bottom: -60px;
    left: -80px;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 14%, transparent), transparent 65%);
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 0 0 16px;
    border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--line));
    border-radius: 999px;
    padding: 5px 12px;
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1,
  h2,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 820px;
    margin-bottom: 12px;
    font-size: clamp(2.5rem, 5vw, 4.75rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    background: linear-gradient(135deg, var(--text) 30%, var(--text) 52%, var(--accent) 80%, var(--accent-soft) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero p:not(.eyebrow) {
    max-width: 600px;
    color: var(--muted);
    font-size: 1.15rem;
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 20px;
  }

  .hero-facts {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    max-width: 660px;
    margin: 16px 0 0;
  }

  .hero-facts div {
    border: 1px solid color-mix(in srgb, var(--accent) 14%, var(--line));
    border-radius: var(--radius-lg);
    padding: 12px;
    background:
      radial-gradient(
        ellipse 80% 55% at 10% 0%,
        color-mix(in srgb, var(--accent) 8%, transparent),
        transparent 62%
      ),
      linear-gradient(
        170deg,
        color-mix(in srgb, var(--surface) 88%, transparent),
        color-mix(in srgb, var(--surface) 72%, transparent)
      );
    backdrop-filter: blur(14px) saturate(1.4);
    box-shadow:
      0 4px 14px color-mix(in srgb, var(--accent) 6%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 16%, transparent);
    transition:
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.25s ease,
      border-color 0.2s ease;
  }

  .hero-facts div:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--accent) 28%, var(--line));
    box-shadow:
      0 8px 22px color-mix(in srgb, var(--accent) 10%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 20%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-facts div {
      transition: none;
    }
  }

  .hero-facts dt {
    margin: 0 0 4px;
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .hero-facts dd {
    margin: 0;
    color: var(--text);
    font-size: 0.9rem;
    font-weight: 800;
  }

  @media (max-width: 840px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 18px;
      padding-block-start: 20px;
    }

    .hero-facts {
      grid-template-columns: 1fr;
    }
  }
</style>
