---
import ThemeToggle from '@/components/ThemeToggle.astro'
---

<header class="topbar">
  <nav class="shell nav" aria-label="Main">
    <a href="/" class="brand" aria-label="Nomad Counter">
      <picture>
        <source srcset="/logo-dark.svg" media="(prefers-color-scheme: dark)" />
        <img src="/logo.svg" alt="Nomad Counter" width="310" height="80" />
      </picture>
    </a>
    <div class="nav-actions">
      <a class="nav-link" href="/stats/">Stats</a>
      <ThemeToggle />
      <div class="nav-sep" aria-hidden="true"></div>
      <a class="btn nav-cta" href="#counter">Start counting</a>
    </div>
  </nav>
</header>

<style is:global>
/* ── Topbar ─────────────────────────────── */
  .topbar {
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(20px) saturate(1.6);
    -webkit-backdrop-filter: blur(20px) saturate(1.6);
    box-shadow: 0 1px 0 var(--line), 0 4px 20px color-mix(in srgb, var(--accent) 6%, transparent);
    animation: header-enter 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .nav {
    display: flex;
    min-height: 76px;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .brand img {
    display: block;
    width: 220px;
    max-width: 48vw;
    height: auto;
    transition: opacity 0.15s ease;
  }

  .brand:hover img {
    opacity: 0.85;
  }

  .nav-actions,
  .inline-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    height: 40px;
    padding: 0 12px;
    border-radius: var(--radius);
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 650;
    text-decoration: none;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .nav-link:hover {
    color: var(--text);
    background: color-mix(in srgb, var(--accent) 7%, transparent);
  }

  .nav-link:focus-visible,
  .btn-text:focus-visible,
  .icon-button:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  .nav-link:focus-visible {
    color: var(--text);
    background: color-mix(in srgb, var(--accent) 11%, transparent);
  }

  .nav-sep {
    width: 1px;
    height: 22px;
    background: var(--line);
    flex-shrink: 0;
  }

  .nav-cta {
    font-size: 0.88rem;
    min-height: 40px;
    padding: 0 16px;
  }
</style>
