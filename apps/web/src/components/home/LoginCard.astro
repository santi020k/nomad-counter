---
import FormField from '@/components/forms/FormField.astro'
import InputControl from '@/components/forms/InputControl.astro'
---

<form id="login-form" class="card login-card" aria-labelledby="login-card-title" data-login-step="email">
  <p id="sync-state" class="sync-state">Guest mode. Your data stays in this browser until you save it to an account.</p>
  <div class="login-card-head">
    <span class="login-card-icon" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2" /><path d="M3 7l9 6 9-6" /></svg>
    </span>
    <div>
      <h2 id="login-card-title">Save to your account</h2>
      <p id="login-card-sub" class="muted login-card-sub">Enter your email when you want to sync trips across devices. We will send a one-time code — no password to remember.</p>
    </div>
  </div>

  <div id="login-pending-banner" class="login-pending-banner" hidden>
    <span class="login-pending-icon" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-6l-2 7-4-14-2 7H2" /></svg>
    </span>
    <div>
      <p class="login-pending-title">Check your inbox</p>
      <p class="login-pending-text">We sent a 6-digit code to <strong id="login-email-masked"></strong></p>
    </div>
  </div>

  <FormField id="login-email-field" forId="login-email" label="Email">
    <InputControl id="login-email" name="email" type="email" autocomplete="email" required />
  </FormField>
  <FormField
    id="code-field"
    class="field-code"
    hidden
    forId="login-code"
    label="6-digit code"
    hint="Codes expire after a short time. Check spam if you do not see it."
    hintId="login-code-help"
  >
    <InputControl
      id="login-code"
      name="code"
      class="input-code"
      type="text"
      inputmode="numeric"
      autocomplete="one-time-code"
      pattern="[0-9]{6}"
      maxlength="6"
      placeholder="000000"
      spellcheck="false"
      aria-describedby="login-code-help"
    />
  </FormField>

  <p id="status" class="login-status" role="status" aria-live="polite"></p>

  <div class="login-actions">
    <button type="submit" class="btn" id="login-primary-btn">Email me a code</button>
    <button type="button" class="btn-text" id="login-change-email" hidden>← Use a different email</button>
    <button type="button" class="btn secondary" id="login-sign-out" hidden>Sign out</button>
  </div>
</form>
