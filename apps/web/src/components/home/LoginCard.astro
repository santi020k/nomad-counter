---
import FormField from '@/components/forms/FormField.astro'
import InputControl from '@/components/forms/InputControl.astro'
---

<form id="login-form" class="card login-card" aria-labelledby="login-card-title" data-login-step="email">
  <p id="sync-state" class="sync-state">Guest mode. Your data stays in this browser until you save it to an account.</p>
  <div class="login-card-head">
    <span class="login-card-icon" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2" /><path d="M3 7l9 6 9-6" /></svg>
    </span>
    <div>
      <h2 id="login-card-title">Save to your account</h2>
      <p id="login-card-sub" class="muted login-card-sub">Enter your email when you want to sync trips across devices. We will send a one-time code — no password to remember.</p>
    </div>
  </div>

  <div id="login-pending-banner" class="login-pending-banner" hidden>
    <span class="login-pending-icon" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-6l-2 7-4-14-2 7H2" /></svg>
    </span>
    <div>
      <p class="login-pending-title">Check your inbox</p>
      <p class="login-pending-text">We sent a 6-digit code to <strong id="login-email-masked"></strong></p>
    </div>
  </div>

  <FormField id="login-email-field" forId="login-email" label="Email">
    <InputControl id="login-email" name="email" type="email" autocomplete="email" required />
  </FormField>
  <FormField
    id="code-field"
    class="field-code"
    hidden
    forId="login-code"
    label="6-digit code"
    hint="Codes expire after a short time. Check spam if you do not see it."
    hintId="login-code-help"
  >
    <InputControl
      id="login-code"
      name="code"
      class="input-code"
      type="text"
      inputmode="numeric"
      autocomplete="one-time-code"
      pattern="[0-9]{6}"
      maxlength="6"
      placeholder="000000"
      spellcheck="false"
      aria-describedby="login-code-help"
    />
  </FormField>

  <p id="status" class="login-status" role="status" aria-live="polite"></p>

  <div class="login-actions">
    <button type="submit" class="btn" id="login-primary-btn">Email me a code</button>
    <button type="button" class="btn-text" id="login-change-email" hidden>← Use a different email</button>
    <button type="button" class="btn secondary" id="login-sign-out" hidden>Sign out</button>
  </div>
</form>

<style is:global>
/* ── Login card ─────────────────────────── */
  .login-card,
  .panel {
    padding: 20px;
  }

  .login-card {
    display: grid;
    gap: 14px;
    background: color-mix(in srgb, var(--surface) 78%, transparent);
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid color-mix(in srgb, var(--line) 70%, transparent);
    box-shadow: var(--shadow-lg), inset 0 1px 0 color-mix(in srgb, white 20%, transparent);
  }

  .login-card h2 {
    margin: 0;
    font-size: 1.2rem;
  }

  .sync-state {
    margin: 0;
    border: 1px solid color-mix(in srgb, var(--accent) 20%, var(--line));
    border-left: 3px solid var(--accent);
    border-radius: var(--radius);
    padding: 9px 12px;
    background: color-mix(in srgb, var(--accent) 5%, transparent);
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1.5;
  }

  .login-card-head {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .login-card-icon {
    display: grid;
    flex-shrink: 0;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: 12px;
    color: var(--accent);
    background: linear-gradient(
      145deg,
      color-mix(in srgb, var(--accent) 22%, transparent),
      color-mix(in srgb, var(--accent) 6%, transparent)
    );
    border: 1px solid color-mix(in srgb, var(--accent) 32%, var(--line));
    box-shadow: 0 4px 14px color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .login-card-icon svg {
    display: block;
  }

  .login-card-sub {
    margin: 6px 0 0;
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .login-pending-banner {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin: 0;
    padding: 14px 14px 14px 16px;
    border-radius: var(--radius);
    border: 1px solid color-mix(in srgb, var(--success) 35%, var(--line));
    background: linear-gradient(
      120deg,
      color-mix(in srgb, var(--success) 12%, transparent),
      color-mix(in srgb, var(--accent) 6%, transparent)
    );
    animation: login-banner-in 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes login-banner-in {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }

    to {
      opacity: 1;
      transform: none;
    }
  }

  .login-pending-icon {
    display: grid;
    flex-shrink: 0;
    place-items: center;
    width: 38px;
    height: 38px;
    margin-top: 2px;
    border-radius: 10px;
    color: var(--success);
    background: color-mix(in srgb, var(--success) 14%, transparent);
  }

  .login-pending-title {
    margin: 0 0 4px;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--success) 85%, var(--text));
  }

  .login-pending-text {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--muted);
  }

  .login-pending-text strong {
    color: var(--text);
    font-weight: 800;
  }

  .login-status {
    min-height: 22px;
    margin: 0;
    color: var(--accent);
    font-size: 0.88rem;
    font-weight: 600;
    line-height: 1.45;
  }

  .login-status[data-tone="error"] {
    color: var(--danger);
  }

  .login-status[data-tone="success"] {
    color: var(--success);
  }

  .login-actions {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    flex-wrap: wrap;
    gap: 10px;
  }

  #login-sign-out.secondary {
    width: 100%;
  }

  .btn-text {
    align-self: flex-start;
    padding: 6px 4px;
    border: none;
    background: none;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
    transition: color 0.15s ease;
  }

  .btn-text:hover {
    color: var(--accent);
  }

  .btn-text:focus-visible {
    color: var(--text);
    border-radius: 6px;
  }

  #login-form[data-login-step="code"] {
    border-color: color-mix(in srgb, var(--accent) 28%, var(--line));
    box-shadow: var(--shadow-lg), 0 0 0 1px color-mix(in srgb, var(--accent) 12%, transparent);
  }

  #login-form[data-login-step="code"] #login-email-field input:read-only {
    opacity: 0.88;
    cursor: default;
  }

  .form-status {
    min-height: 0;
    margin: 0;
    font-size: 0.88rem;
    font-weight: 600;
    line-height: 1.45;
    color: var(--accent);
  }

  .form-status:empty {
    display: none;
  }

  .form-status[data-tone="error"] {
    color: var(--danger);
  }

  .field-hint {
    display: block;
    margin-top: 8px;
    padding-left: 10px;
    border-left: 2px solid color-mix(in srgb, var(--accent) 32%, var(--line));
    color: var(--muted);
    font-size: 0.78rem;
    line-height: 1.45;
  }
</style>
