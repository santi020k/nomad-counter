---
import InputControl from '@/components/forms/InputControl.astro'
import SectionHeading from '@/components/ui/SectionHeading.astro'
---

<section class="panel trip-log-panel" aria-labelledby="trip-log-heading">
  <div class="panel-heading trip-log-heading">
    <SectionHeading
      class="panel-title-stack"
      contentClass="trip-log-title-block"
      eyebrow="Trips"
      icon="route"
      iconClass="panel-icon panel-icon--route"
      iconSize={22}
      lede="Newest stays first. Export or import CSV to move your history between devices."
      ledeClass="muted trip-log-lede"
      title="Travel log"
      titleId="trip-log-heading"
    />
    <div class="inline-actions trip-log-actions" role="group" aria-label="Trip data">
      <button id="export-csv" class="btn secondary" type="button">Export CSV</button>
      <label class="btn secondary">
        Import CSV
        <InputControl id="import-csv" class="sr-only" type="file" accept=".csv,text/csv" />
      </label>
    </div>
  </div>
  <ul id="trip-list" class="list trip-log-list" aria-labelledby="trip-log-heading">
    <li class="trip-log-empty-item">
      <p class="muted empty-state trip-log-empty" role="status">No trips yet. Add your first stay or import a CSV.</p>
    </li>
  </ul>
</section>
