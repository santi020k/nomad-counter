---
import HomeCountryPanel from './HomeCountryPanel.astro'
import SummaryPanel from './SummaryPanel.astro'
import TripFormPanel from './TripFormPanel.astro'
import TripLogPanel from './TripLogPanel.astro'
---

<section id="counter" class="app-grid" aria-label="Nomad Counter app" data-animate>
  <div class="dashboard">
    <SummaryPanel />
    <TripLogPanel />
  </div>

  <div class="sidebar">
    <TripFormPanel />
    <HomeCountryPanel />
  </div>
</section>

<style is:global>
/* ── App grid ───────────────────────────── */
  .app-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 18px;
    align-items: start;
    margin-top: 36px;
  }

  [data-authenticated="true"] .app-grid {
    display: grid;
  }

  .dashboard,
  .sidebar,
  .form-panel {
    display: grid;
    gap: 18px;
  }

  .panel {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--surface);
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .panel:hover {
    box-shadow: var(--shadow-sm);
  }

  .panel:focus-within {
    border-color: color-mix(in srgb, var(--accent) 34%, var(--line));
    box-shadow: var(--shadow-sm), var(--focus-ring);
  }

  .panel-heading {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 18px;
  }

  .panel-heading .eyebrow {
    margin-bottom: 4px;
    font-size: 0.72rem;
  }

  .panel-heading h2 {
    margin: 0;
    font-size: 1.1rem;
  }

  .window-label {
    margin: 4px 0 0;
    font-size: 0.82rem;
  }

  .panel-title-stack {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    min-width: 0;
  }

  .summary-panel {
    padding: 18px;
    background:
      linear-gradient(
        165deg,
        color-mix(in srgb, var(--accent) 4%, transparent),
        transparent 44%
      ),
      var(--surface);
  }

  .trip-log-panel {
    background:
      linear-gradient(
        168deg,
        color-mix(in srgb, var(--accent) 3.5%, transparent),
        transparent 42%
      ),
      var(--surface);
  }

  .trip-log-heading {
    align-items: flex-start;
    padding-bottom: 16px;
    margin-bottom: 14px;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 16%, var(--line));
  }

  .trip-log-title-block {
    display: grid;
    gap: 4px;
    min-width: 0;
  }

  .trip-log-title-block h2 {
    font-size: 1.12rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .trip-log-lede {
    margin: 2px 0 0;
    max-width: 42ch;
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .trip-log-actions {
    flex-shrink: 0;
  }

  .trip-log-list {
    list-style: none;
    margin: 0;
    padding-inline-start: 0;
  }

  .trip-log-list:has(.trip-log-item) {
    gap: 12px;
  }

  .trip-log-item,
  .trip-log-empty-item {
    margin: 0;
    padding: 0;
  }

  .trip-log-empty-item {
    grid-column: 1 / -1;
    list-style: none;
  }

  .trip-log-empty-item .trip-log-empty {
    margin: 0;
  }

  .summary-heading {
    margin-bottom: 16px;
    gap: 14px;
  }

  .summary-title-content {
    display: grid;
    gap: 2px;
  }

  .summary-title-content h2 {
    letter-spacing: -0.015em;
  }

  .summary-window {
    display: grid;
    gap: 6px;
    min-width: 220px;
    padding: 10px 12px;
    border-radius: var(--radius);
    border: 1px solid color-mix(in srgb, var(--accent) 16%, var(--line));
    background: color-mix(in srgb, var(--surface-strong) 86%, transparent);
  }

  .summary-window small {
    margin-top: 2px;
    font-size: 0.76rem;
    line-height: 1.4;
  }

  .panel-icon {
    display: grid;
    flex-shrink: 0;
    place-items: center;
    width: 44px;
    height: 44px;
    margin-top: 2px;
    border-radius: 12px;
    color: var(--accent);
    background: linear-gradient(
      145deg,
      color-mix(in srgb, var(--accent) 24%, transparent),
      color-mix(in srgb, var(--accent) 7%, transparent)
    );
    border: 1px solid color-mix(in srgb, var(--accent) 38%, var(--line));
    box-shadow: 0 4px 18px color-mix(in srgb, var(--accent) 16%, transparent);
  }

  .panel-icon svg {
    display: block;
    opacity: 0.92;
  }

  .form-panel-title {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0;
    padding-bottom: 10px;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 22%, var(--line));
    font-size: 1.12rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .form-panel-heading {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding-bottom: 14px;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 22%, var(--line));
  }

  .form-panel-heading-text {
    min-width: 0;
  }

  .form-panel-heading .eyebrow {
    margin-bottom: 6px;
  }

  .form-panel-heading-title {
    margin: 0;
    font-size: 1.12rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .form-panel-heading .form-panel-icon {
    margin-top: 2px;
    flex-shrink: 0;
  }

  .trip-form-dates-block {
    margin: 0;
    padding: 0;
    border: none;
    min-width: 0;
    display: grid;
    gap: 12px;
  }

  .trip-form-date-grid {
    gap: 12px;
  }

  .trip-open-ended-hint {
    margin: -4px 0 0;
    padding-left: 10px;
    border-left: 2px solid color-mix(in srgb, var(--accent) 28%, var(--line));
    font-size: 0.76rem;
    line-height: 1.45;
    color: var(--muted);
  }

  .form-panel-footer {
    display: grid;
    gap: 12px;
    padding-top: 6px;
    margin-top: 2px;
    border-top: 1px solid color-mix(in srgb, var(--accent) 14%, var(--line));
  }

  #trip-form .form-panel-footer .btn {
    width: 100%;
  }

  .form-panel-icon {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 32%, var(--line));
  }

  .compact {
    min-width: 190px;
  }

  .field small,
  .form-help {
    color: var(--muted);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .form-help {
    display: grid;
    gap: 4px;
    margin: -4px 0 0;
  }

  .empty-state {
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 0;
    padding: 18px 16px;
    border-radius: var(--radius);
    border: 1px dashed color-mix(in srgb, var(--accent) 32%, var(--line));
    background: linear-gradient(
      125deg,
      color-mix(in srgb, var(--accent) 10%, transparent) 0%,
      transparent 58%
    );
  }

  .empty-state::before {
    content: '';
    flex-shrink: 0;
    width: 42px;
    height: 42px;
    border-radius: 14px;
    background:
      radial-gradient(circle at 32% 28%, color-mix(in srgb, var(--accent-soft) 90%, transparent), transparent 52%),
      linear-gradient(150deg, var(--accent-soft), var(--accent));
    opacity: 0.42;
    box-shadow: inset 0 1px 0 color-mix(in srgb, white 22%, transparent);
  }

/* ── Shared confirm dialog (summary + travel log) ──────────────── */
  .confirm-action-dialog {
    position: fixed;
    top: 50%;
    left: 50%;
    width: min(calc(100% - 24px), 26rem);
    max-width: none;
    max-height: min(90dvh, calc(100% - 24px));
    margin: 0;
    padding: 0;
    overflow: auto;
    border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--line));
    border-radius: var(--radius-lg);
    background: var(--surface-strong);
    box-shadow: var(--shadow-lg);
    color: var(--text);
    transform: translate(-50%, -50%);
  }

  .confirm-action-dialog::backdrop {
    background: color-mix(in srgb, var(--text) 38%, transparent);
    backdrop-filter: blur(4px);
  }

  .confirm-action-dialog-box {
    padding: 22px 22px 20px;
  }

  .confirm-action-dialog-box h2 {
    margin: 0 0 12px;
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .confirm-action-dialog-desc {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .confirm-action-dialog-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 10px;
    margin-top: 22px;
  }

  /* ── Trip list rows ─────────────────────── */
  .list {
    display: grid;
    gap: 10px;
  }

  .tight {
    margin-top: 8px;
  }

  .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 12px 14px;
    background:
      linear-gradient(155deg, color-mix(in srgb, var(--accent) 7%, transparent), transparent 50%),
      var(--surface-strong);
    transition: border-color 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
  }

  .row-trip,
  .row-tracked {
    padding: 0;
    overflow: hidden;
    gap: 0;
  }

  .row-accent {
    flex-shrink: 0;
    width: 4px;
    align-self: stretch;
    min-height: 52px;
    background: linear-gradient(180deg, var(--accent), var(--accent-soft));
  }

  .row-tracked .row-accent {
    background: linear-gradient(180deg, var(--success), color-mix(in srgb, var(--success) 55%, var(--sky)));
  }

  .row-body {
    display: flex;
    flex: 1;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    min-width: 0;
    padding: 12px 14px 12px 10px;
  }

  .row-flag-wrap {
    display: inline-grid;
    place-items: center;
    width: 2.1rem;
    height: 2.1rem;
    margin-right: 2px;
    border-radius: 8px;
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 28%, var(--line));
    vertical-align: middle;
  }

  .row-flag-wrap .row-flag,
  .row-flag-wrap .cc-flag {
    font-size: 1.15rem;
    line-height: 1;
  }

  .trip-dates {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    margin-top: 2px;
  }

  .date-pill {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 12%, var(--surface-strong));
    border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--line));
    color: var(--text);
    font-size: 0.78rem;
    font-weight: 650;
    letter-spacing: 0.01em;
  }

  .date-pill--open {
    background: color-mix(in srgb, var(--success) 14%, var(--surface-strong));
    border-color: color-mix(in srgb, var(--success) 35%, var(--line));
    color: color-mix(in srgb, var(--success) 92%, var(--text));
  }

  /* Trip rows are injected in app.ts without data-astro-cid — scope via #trip-list :global */
  #trip-list :global(.trip-dates--log) {
    gap: 8px;
  }

  #trip-list :global(.date-pill--log) {
    position: relative;
    display: inline-flex;
    align-items: stretch;
    padding: 0;
    padding-right: 11px;
    border-radius: 10px;
    overflow: hidden;
    vertical-align: middle;
    color: var(--text);
    font-size: 0.78rem;
    font-weight: 650;
    letter-spacing: 0.01em;
    background:
      linear-gradient(180deg, color-mix(in srgb, white 3%, transparent), transparent 38%),
      color-mix(in srgb, var(--accent) 11%, var(--surface-strong));
    border: 1px solid color-mix(in srgb, var(--accent) 28%, var(--line));
    box-shadow: inset 0 1px 1px color-mix(in srgb, var(--text) 5%, transparent);
  }

  #trip-list :global(.date-pill--log .date-pill__accent) {
    flex-shrink: 0;
    width: 4px;
    align-self: stretch;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--accent) 82%, transparent),
      color-mix(in srgb, var(--accent-soft) 55%, transparent)
    );
  }

  #trip-list :global(.date-pill--log .date-pill__text) {
    display: inline-flex;
    align-items: center;
    padding: 5px 0 5px 8px;
  }

  #trip-list :global(.date-pill--log.date-pill--open) {
    background:
      linear-gradient(180deg, color-mix(in srgb, white 3%, transparent), transparent 38%),
      color-mix(in srgb, var(--success) 12%, var(--surface-strong));
    border-color: color-mix(in srgb, var(--success) 38%, var(--line));
    color: color-mix(in srgb, var(--success) 92%, var(--text));
  }

  #trip-list :global(.date-pill--log.date-pill--open .date-pill__accent) {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--success) 75%, transparent),
      color-mix(in srgb, var(--sky) 48%, transparent)
    );
  }

  .trip-dates-arrow {
    color: var(--muted);
    font-size: 0.85rem;
    font-weight: 600;
  }

  .row:hover {
    border-color: color-mix(in srgb, var(--accent) 20%, var(--line));
    box-shadow: var(--shadow-sm);
  }

  .row:focus-within {
    border-color: color-mix(in srgb, var(--accent) 34%, var(--line));
    box-shadow: var(--shadow-sm), var(--focus-ring);
    background: color-mix(in srgb, var(--accent) 2.5%, var(--surface-strong));
  }

  .row-info {
    display: grid;
    gap: 6px;
  }

  .row-info strong {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.92rem;
    font-weight: 700;
  }

  #trip-list :global(.trip-card-title) {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: -0.012em;
    line-height: 1.25;
    color: var(--text);
  }

  #trip-list :global(.trip-card-title__name) {
    min-width: 0;
  }

  .row-flag {
    font-size: 1.2rem;
    line-height: 1;
  }

  .trip-note {
    margin: 0;
    max-width: 52ch;
    color: color-mix(in srgb, var(--muted) 82%, var(--text));
    font-size: 0.8rem;
    line-height: 1.5;
    word-break: break-word;
  }

  #trip-list :global(.row-trip) {
    min-height: 3.25rem;
  }

  .tracked-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tracked-pill {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    border: 1px solid color-mix(in srgb, var(--accent) 28%, var(--line));
    border-radius: 999px;
    padding: 0 9px;
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    color: color-mix(in srgb, var(--accent) 92%, var(--text));
    font-size: 0.72rem;
    font-weight: 700;
  }

  .tracked-pill--warning {
    border-color: color-mix(in srgb, var(--warn) 36%, var(--line));
    background: color-mix(in srgb, var(--warn) 12%, transparent);
    color: color-mix(in srgb, var(--warn) 74%, var(--text));
  }

  .row-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .trip-days {
    display: inline-flex;
    align-items: center;
    border: 1px solid color-mix(in srgb, var(--accent) 25%, var(--line));
    border-radius: 6px;
    padding: 2px 8px;
    background: color-mix(in srgb, var(--accent) 7%, transparent);
    color: var(--accent);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .row-remove-button {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 34px;
    border: 1px solid color-mix(in srgb, var(--danger) 32%, var(--line));
    border-radius: var(--radius);
    padding: 0 10px;
    background: color-mix(in srgb, var(--danger) 7%, transparent);
    color: color-mix(in srgb, var(--danger) 86%, var(--text));
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease, box-shadow 0.15s ease;
  }

  .row-remove-button:hover {
    border-color: color-mix(in srgb, var(--danger) 56%, var(--line));
    color: var(--danger);
    background: color-mix(in srgb, var(--danger) 12%, transparent);
  }

  .row-remove-button:focus-visible {
    border-color: color-mix(in srgb, var(--danger) 46%, var(--line));
    color: color-mix(in srgb, var(--danger) 88%, var(--text));
    background: color-mix(in srgb, var(--danger) 8%, transparent);
  }

  @media (max-width: 520px) {
    .row-trip .row-body {
      flex-direction: column;
      align-items: stretch;
      gap: 12px;
    }

    .row-trip .row-meta {
      justify-content: space-between;
      width: 100%;
      padding-top: 12px;
      border-top: 1px solid color-mix(in srgb, var(--accent) 14%, var(--line));
    }
  }

  /* ── Form panel ─────────────────────────── */
  #trip-form-status,
  #home-country-form-status {
    min-height: 1.3rem;
  }

  #trip-form-status:empty,
  #home-country-form-status:empty {
    display: block;
    visibility: hidden;
  }
</style>
