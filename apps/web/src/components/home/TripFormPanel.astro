---
import CheckboxControl from '@/components/forms/CheckboxControl.astro'
import CountryComboboxField from '@/components/forms/CountryComboboxField.astro'
import DateShell from '@/components/forms/DateShell.astro'
import FormField from '@/components/forms/FormField.astro'
import InputControl from '@/components/forms/InputControl.astro'
import TextareaControl from '@/components/forms/TextareaControl.astro'
import SectionHeading from '@/components/ui/SectionHeading.astro'
---

<form id="trip-form" class="panel form-panel" novalidate>
  <SectionHeading
    class="form-panel-heading"
    contentClass="form-panel-heading-text"
    eyebrow="New stay"
    icon="route"
    iconClass="form-panel-icon form-panel-icon--route"
    title="Add trip"
    titleClass="form-panel-heading-title"
  />
  <CountryComboboxField
    fieldLabel="Country"
    comboLabel="Trip country"
    searchId="trip-country-search"
    listboxId="trip-country-listbox"
    selectId="trip-country"
    selectName="countryCode"
  />
  <fieldset class="trip-form-dates-block">
    <legend class="sr-only">Stay dates</legend>
    <div class="grid-fit trip-form-date-grid">
      <FormField forId="trip-entry" label="Entry date">
        <DateShell>
          <InputControl
            id="trip-entry"
            name="entryDate"
            type="date"
            required
            class="ui-input--date"
          />
        </DateShell>
      </FormField>
      <FormField
        forId="trip-exit"
        label="Exit date"
        hint="Required for completed stays. Disabled while “Currently there” is checked."
        hintId="trip-exit-help"
      >
        <DateShell>
          <InputControl
            id="trip-exit"
            name="exitDate"
            type="date"
            required
            class="ui-input--date"
            aria-describedby="trip-exit-help"
          />
        </DateShell>
      </FormField>
    </div>
    <CheckboxControl
      id="trip-open-ended"
      inputName="openEnded"
      label="Currently there"
      aria-describedby="trip-open-ended-help"
    />
    <p id="trip-open-ended-help" class="trip-open-ended-hint">
      When checked, exit date is optional until the stay ends.
    </p>
  </fieldset>
  <FormField forId="trip-note" label="Note" hint="Avoid sensitive tax, immigration, or identity details." hintId="trip-note-help">
    <TextareaControl id="trip-note" name="note" rows="3" placeholder="Optional" aria-describedby="trip-note-help" />
  </FormField>
  <div class="form-panel-footer">
    <p id="trip-form-status" class="form-status" role="status" aria-live="polite"></p>
    <button class="btn" type="submit">Add trip</button>
  </div>
</form>
