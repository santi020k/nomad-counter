---
import SelectControl from '@/components/forms/SelectControl.astro'
import SectionHeading from '@/components/ui/SectionHeading.astro'
---

<section class="panel summary-panel">
  <div class="panel-heading summary-heading">
    <SectionHeading
      class="panel-title-stack"
      contentClass="summary-title-content"
      eyebrow="Exposure"
      icon="chart"
      iconClass="panel-icon panel-icon--chart"
      iconSize={22}
      lede="Current calendar year"
      ledeClass="muted window-label"
      ledeId="window-label"
      title="Country day counts"
      titleId="summary-panel-heading"
    />
    <div class="field compact summary-window">
      <label for="window-mode">Window</label>
      <SelectControl id="window-mode" aria-describedby="window-help">
        <option value="calendar-year">Calendar year</option>
        <option value="rolling-365">Rolling 365 days</option>
      </SelectControl>
      <small id="window-help">Choose the date range used for exposure counts.</small>
    </div>
  </div>
  <ul id="summary-list" class="summary-list" aria-labelledby="summary-panel-heading">
    <li class="summary-list-empty">
      <p class="muted empty-state">Add a trip to see your residency exposure by country.</p>
    </li>
  </ul>
  <p class="rule">
    Counting rule: any calendar day with presence in a country counts as one full day. Entry and exit dates are inclusive. This is a tracking aid, not tax advice.
  </p>
</section>

<style is:global>
/* ── Country summary cards ──────────────── */
  .summary-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 252px), 1fr));
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  /* Client-rendered summary cards live under .summary-panel without data-astro-cid; use :global so SVG fills etc. apply */
  .summary-panel :global(.summary-list-item) {
    min-width: 0;
  }

  .summary-list-empty {
    grid-column: 1 / -1;
    list-style: none;
  }

  .summary-list-empty .empty-state {
    width: 100%;
  }

  .summary-panel :global(.country-card) {
    position: relative;
    display: grid;
    gap: 12px;
    border: 1px solid color-mix(in srgb, var(--accent) 16%, var(--line));
    border-radius: var(--radius-lg);
    padding: 14px;
    background:
      linear-gradient(155deg, color-mix(in srgb, var(--accent) 5%, transparent), transparent 44%),
      var(--surface-strong);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .summary-panel :global(.country-card::after) {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--accent), var(--accent-soft));
    opacity: 0.7;
  }

  .summary-panel :global(.country-card:hover) {
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
    border-color: color-mix(in srgb, var(--accent) 30%, var(--line));
  }

  .summary-panel :global(.country-card[data-level="warning"]) {
    border-color: color-mix(in srgb, var(--warn) 54%, var(--line));
  }

  .summary-panel :global(.country-card[data-level="warning"]::after) {
    background: linear-gradient(90deg, var(--warn), color-mix(in srgb, var(--warn) 64%, var(--accent-soft)));
  }

  .summary-panel :global(.country-card[data-level="exceeded"]) {
    border-color: color-mix(in srgb, var(--danger) 56%, var(--line));
  }

  .summary-panel :global(.country-card[data-level="exceeded"]::after) {
    background: linear-gradient(90deg, var(--danger), color-mix(in srgb, var(--danger) 64%, var(--accent-soft)));
  }

  .summary-panel :global(.cc-top) {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 12px;
    z-index: 1;
  }

  .summary-panel :global(.cc-flag-wrap) {
    display: grid;
    flex-shrink: 0;
    place-items: center;
    width: 4.75rem;
    height: 3.65rem;
    border-radius: 14px;
    background:
      radial-gradient(120% 100% at 30% 20%, color-mix(in srgb, white 16%, transparent), transparent 55%),
      linear-gradient(
        155deg,
        color-mix(in srgb, var(--accent) 22%, var(--surface-strong)),
        color-mix(in srgb, var(--accent) 8%, var(--surface-strong))
      );
    border: 1px solid color-mix(in srgb, var(--accent) 34%, var(--line));
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 18%, transparent),
      0 6px 18px color-mix(in srgb, var(--accent) 14%, transparent);
    font-size: 2.35rem;
    line-height: 1;
  }

  .summary-panel :global(.cc-flag-wrap .cc-flag) {
    font-size: inherit;
    filter: drop-shadow(0 1px 1px color-mix(in srgb, var(--text) 12%, transparent));
  }

  .summary-panel :global(.country-card[data-level="warning"] .cc-flag-wrap) {
    border-color: color-mix(in srgb, var(--warn) 48%, var(--line));
    background: color-mix(in srgb, var(--warn) 10%, var(--surface-strong));
  }

  .summary-panel :global(.country-card[data-level="exceeded"] .cc-flag-wrap) {
    border-color: color-mix(in srgb, var(--danger) 48%, var(--line));
    background: color-mix(in srgb, var(--danger) 10%, var(--surface-strong));
  }

  .summary-panel :global(.cc-main) {
    flex: 1;
    min-width: 0;
    display: grid;
    gap: 6px;
  }

  .summary-panel :global(.cc-header) {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
  }

  .summary-panel :global(.cc-header-end) {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: flex-end;
    gap: 8px;
  }

  .summary-panel :global(.cc-header-end .cc-level-pill) {
    align-self: center;
    margin-top: 0;
  }

  .summary-panel :global(.cc-actions) {
    position: relative;
    flex-shrink: 0;
  }

  .summary-panel :global(.cc-actions-btn) {
    display: inline-grid;
    place-items: center;
    width: 34px;
    height: 34px;
    margin: 0;
    padding: 0;
    border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--line));
    border-radius: 10px;
    background: color-mix(in srgb, var(--accent) 6%, transparent);
    color: var(--muted);
    cursor: pointer;
    transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }

  .summary-panel :global(.cc-actions-btn:hover) {
    color: var(--text);
    border-color: color-mix(in srgb, var(--accent) 38%, var(--line));
    background: color-mix(in srgb, var(--accent) 11%, transparent);
  }

  .summary-panel :global(.cc-actions-btn[aria-expanded="true"]) {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 42%, var(--line));
    background: color-mix(in srgb, var(--accent) 14%, transparent);
  }

  .summary-panel :global(.cc-actions-btn svg) {
    display: block;
  }

  .summary-panel :global(.cc-actions-menu) {
    position: absolute;
    z-index: 30;
    top: calc(100% + 4px);
    right: 0;
    min-width: 12.5rem;
    padding: 6px;
    border-radius: var(--radius);
    border: 1px solid color-mix(in srgb, var(--accent) 18%, var(--line));
    background: var(--surface-strong);
    box-shadow: var(--shadow);
  }

  .summary-panel :global(.cc-actions-menu-item) {
    display: flex;
    width: 100%;
    align-items: center;
    margin: 0;
    padding: 10px 12px;
    border: none;
    border-radius: 6px;
    background: transparent;
    color: var(--text);
    font-size: 0.88rem;
    font-weight: 650;
    text-align: left;
    cursor: pointer;
    transition: background 0.12s ease, color 0.12s ease;
  }

  .summary-panel :global(.cc-actions-menu-item:hover) {
    background: color-mix(in srgb, var(--danger) 10%, transparent);
    color: color-mix(in srgb, var(--danger) 88%, var(--text));
  }

  .summary-panel :global(.cc-name-row) {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 6px 8px;
    min-width: 0;
  }

  .summary-panel :global(.cc-title) {
    margin: 0;
    font-size: 0.96rem;
    font-weight: 800;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .summary-panel :global(.cc-code) {
    display: inline-block;
    border: 1px solid color-mix(in srgb, var(--accent) 28%, var(--line));
    border-radius: 6px;
    padding: 2px 6px;
    background: color-mix(in srgb, var(--accent) 9%, transparent);
    color: color-mix(in srgb, var(--accent) 86%, var(--text));
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.05em;
  }

  .summary-panel :global(.cc-threshold) {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 4px 6px;
    margin: 0;
    color: color-mix(in srgb, var(--muted) 88%, var(--text));
    font-size: 0.78rem;
    line-height: 1.35;
  }

  .summary-panel :global(.cc-threshold-label) {
    font-weight: 600;
  }

  .summary-panel :global(.cc-threshold-value) {
    font-weight: 700;
    color: color-mix(in srgb, var(--muted) 55%, var(--text));
  }

  .summary-panel :global(.cc-count-row) {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 12px 10px 10px;
    border-radius: var(--radius);
    border: 1px solid color-mix(in srgb, var(--accent) 16%, var(--line));
    background:
      radial-gradient(100% 120% at 0% 50%, color-mix(in srgb, var(--accent) 8%, transparent), transparent 52%),
      color-mix(in srgb, var(--surface) 72%, transparent);
  }

  .summary-panel :global(.cc-count-block) {
    flex: 1;
    min-width: 0;
    display: grid;
    gap: 2px;
  }

  .summary-panel :global(.cc-donut-wrap) {
    position: relative;
    flex-shrink: 0;
    width: 84px;
    height: 84px;
  }

  .summary-panel :global(.cc-donut-wrap::after) {
    content: '';
    position: absolute;
    inset: 10%;
    border-radius: 50%;
    background: radial-gradient(
      circle at 35% 28%,
      color-mix(in srgb, var(--accent-soft) 22%, transparent),
      transparent 58%
    );
    opacity: 0.55;
    pointer-events: none;
  }

  .summary-panel :global(.cc-donut) {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 3px 10px color-mix(in srgb, var(--accent) 22%, transparent));
    transition: filter 0.25s ease;
  }

  .summary-panel :global(.country-card:hover .cc-donut) {
    filter: drop-shadow(0 5px 16px color-mix(in srgb, var(--accent) 30%, transparent));
  }

  .summary-panel :global(.country-card[data-level="warning"] .cc-donut) {
    filter: drop-shadow(0 3px 12px color-mix(in srgb, var(--warn) 28%, transparent));
  }

  .summary-panel :global(.country-card[data-level="warning"]:hover .cc-donut) {
    filter: drop-shadow(0 5px 18px color-mix(in srgb, var(--warn) 36%, transparent));
  }

  .summary-panel :global(.country-card[data-level="exceeded"] .cc-donut) {
    filter: drop-shadow(0 3px 12px color-mix(in srgb, var(--danger) 26%, transparent));
  }

  .summary-panel :global(.country-card[data-level="exceeded"]:hover .cc-donut) {
    filter: drop-shadow(0 5px 18px color-mix(in srgb, var(--danger) 34%, transparent));
  }

  .summary-panel :global(.cc-donut-face) {
    fill: color-mix(in srgb, var(--surface-strong) 88%, var(--line));
  }

  .summary-panel :global(.cc-donut-rim) {
    stroke: color-mix(in srgb, var(--line) 55%, transparent);
    stroke-width: 1.15;
  }

  .summary-panel :global(.cc-donut-track) {
    stroke: color-mix(in srgb, var(--line) 62%, var(--surface) 38%);
    stroke-linecap: round;
  }

  .summary-panel :global(.cc-donut-arc) {
    transition: stroke-dashoffset 0.9s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .summary-panel :global(.cc-donut-grad-start) {
    stop-color: var(--accent);
  }

  .summary-panel :global(.cc-donut-grad-mid) {
    stop-color: var(--accent-strong);
  }

  .summary-panel :global(.cc-donut-grad-end) {
    stop-color: var(--accent-soft);
  }

  .summary-panel :global(.country-card[data-level="warning"] .cc-donut-grad-start) {
    stop-color: color-mix(in srgb, var(--warn) 88%, var(--text));
  }

  .summary-panel :global(.country-card[data-level="warning"] .cc-donut-grad-mid) {
    stop-color: color-mix(in srgb, var(--warn) 72%, var(--accent-soft));
  }

  .summary-panel :global(.country-card[data-level="warning"] .cc-donut-grad-end) {
    stop-color: color-mix(in srgb, var(--warn) 55%, var(--accent-soft));
  }

  .summary-panel :global(.country-card[data-level="exceeded"] .cc-donut-grad-start) {
    stop-color: color-mix(in srgb, var(--danger) 90%, var(--text));
  }

  .summary-panel :global(.country-card[data-level="exceeded"] .cc-donut-grad-mid) {
    stop-color: var(--danger);
  }

  .summary-panel :global(.country-card[data-level="exceeded"] .cc-donut-grad-end) {
    stop-color: color-mix(in srgb, var(--danger) 65%, var(--accent-soft));
  }

  .summary-panel :global(.cc-donut-pct) {
    font-size: 1.05rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.03em;
    fill: var(--text);
  }

  .summary-panel :global(.country-card[data-level="warning"] .cc-donut-pct) {
    fill: color-mix(in srgb, var(--warn) 55%, var(--text));
  }

  .summary-panel :global(.country-card[data-level="exceeded"] .cc-donut-pct) {
    fill: color-mix(in srgb, var(--danger) 58%, var(--text));
  }

  .summary-panel :global(.cc-count) {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin: 0;
    font-variant-numeric: tabular-nums;
  }

  .summary-panel :global(.cc-count-value) {
    font-size: 2.25rem;
    line-height: 1;
    font-weight: 800;
    color: var(--text);
  }

  .summary-panel :global(.cc-count-suffix) {
    color: var(--muted);
    font-size: 0.84rem;
    font-weight: 600;
  }

  .summary-panel :global(.cc-pct) {
    margin: 0;
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0.02em;
  }

  .summary-panel :global(.cc-level-pill) {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    margin-top: 1px;
    white-space: nowrap;
    padding: 4px 9px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--accent) 25%, var(--line));
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    color: color-mix(in srgb, var(--accent) 85%, var(--text));
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .summary-panel :global(.country-card[data-level="warning"] .cc-level-pill) {
    border-color: color-mix(in srgb, var(--warn) 48%, var(--line));
    background: color-mix(in srgb, var(--warn) 14%, transparent);
    color: color-mix(in srgb, var(--warn) 85%, var(--text));
  }

  .summary-panel :global(.country-card[data-level="exceeded"] .cc-level-pill) {
    border-color: color-mix(in srgb, var(--danger) 48%, var(--line));
    background: color-mix(in srgb, var(--danger) 14%, transparent);
    color: color-mix(in srgb, var(--danger) 90%, var(--text));
  }

  .summary-panel :global(.cc-status) {
    margin: 0;
    color: color-mix(in srgb, var(--muted) 82%, var(--text));
    font-size: 0.82rem;
    font-weight: 600;
  }

  .summary-panel :global([data-level="warning"] .cc-status) {
    color: color-mix(in srgb, var(--warn) 62%, var(--text));
  }

  .summary-panel :global([data-level="exceeded"] .cc-status) {
    color: color-mix(in srgb, var(--danger) 80%, var(--text));
  }

/* ── Progress meter (summary cards are client-rendered) ─────────────────────── */
  .summary-panel :global(.meter) {
    position: relative;
    overflow: hidden;
    height: 8px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--line) 78%, transparent);
  }

  .summary-panel :global(.meter i) {
    display: block;
    height: 100%;
    width: var(--w, 0%);
    border-radius: inherit;
    background: linear-gradient(90deg, var(--accent), var(--accent-soft));
    box-shadow: 0 0 10px color-mix(in srgb, var(--accent) 30%, transparent);
    animation: meter-grow 1s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .summary-panel :global([data-level="warning"] .meter i) {
    background: linear-gradient(90deg, var(--warn), color-mix(in srgb, var(--warn) 60%, var(--accent-soft)));
  }

  .summary-panel :global([data-level="exceeded"] .meter i) {
    background: linear-gradient(90deg, var(--danger), color-mix(in srgb, var(--danger) 70%, var(--accent-soft)));
  }

  @keyframes meter-grow {
    from { clip-path: inset(0 100% 0 0 round 999px); }
    to { clip-path: inset(0 0% 0 0 round 999px); }
  }

/* ── Rules note ─────────────────────────── */
  .rule {
    margin: 16px 0 0;
    padding: 12px;
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--accent) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 12%, transparent);
    color: color-mix(in srgb, var(--muted) 70%, var(--text));
    font-size: 0.85rem;
    line-height: 1.55;
  }
</style>
