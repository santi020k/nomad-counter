---
import SelectControl from '@/components/forms/SelectControl.astro'
---

<section class="panel summary-panel">
  <div class="panel-heading summary-heading">
    <div class="panel-title-stack">
      <span class="panel-icon panel-icon--chart" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18" /><path d="M7 16l4-4 4 4 6-7" /></svg>
      </span>
      <div class="summary-title-content">
        <p class="eyebrow">Exposure</p>
        <h2 id="summary-panel-heading">Country day counts</h2>
        <p id="window-label" class="muted window-label">Current calendar year</p>
      </div>
    </div>
    <div class="field compact summary-window">
      <label for="window-mode">Window</label>
      <SelectControl id="window-mode" aria-describedby="window-help">
        <option value="calendar-year">Calendar year</option>
        <option value="rolling-365">Rolling 365 days</option>
      </SelectControl>
      <small id="window-help">Choose the date range used for exposure counts.</small>
    </div>
  </div>
  <ul id="summary-list" class="summary-list" aria-labelledby="summary-panel-heading">
    <li class="summary-list-empty">
      <p class="muted empty-state">Add a trip to see your residency exposure by country.</p>
    </li>
  </ul>
  <p class="rule">
    Counting rule: any calendar day with presence in a country counts as one full day. Entry and exit dates are inclusive. This is a tracking aid, not tax advice.
  </p>
</section>
