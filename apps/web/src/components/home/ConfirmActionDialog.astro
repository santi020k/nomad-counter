<dialog id="confirm-action-dialog" class="confirm-action-dialog" aria-labelledby="confirm-action-dialog-title">
  <div class="confirm-action-dialog-box">
    <h2 id="confirm-action-dialog-title"></h2>
    <p id="confirm-action-dialog-desc" class="muted confirm-action-dialog-desc"></p>
    <div class="confirm-action-dialog-actions">
      <button type="button" class="btn secondary" id="confirm-action-cancel">Cancel</button>
      <button
        type="button"
        class="btn danger"
        id="confirm-action-confirm"
        aria-describedby="confirm-action-dialog-desc"
      >
        Remove
      </button>
    </div>
  </div>
</dialog>
