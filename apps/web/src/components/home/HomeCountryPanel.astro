---
import CountryComboboxField from '@/components/forms/CountryComboboxField.astro'
import FormField from '@/components/forms/FormField.astro'
import InputControl from '@/components/forms/InputControl.astro'
---

<form id="home-country-form" class="panel form-panel">
  <h2 class="form-panel-title">
    <span class="form-panel-icon" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20" /></svg>
    </span>
    Tracked country
  </h2>
  <CountryComboboxField
    fieldLabel="Country"
    comboLabel="Tracked country"
    searchId="home-country-search"
    listboxId="home-country-listbox"
    selectId="home-country"
    selectName="countryCode"
  />
  <div class="grid-fit">
    <FormField forId="threshold-days" label="Threshold">
      <InputControl
        id="threshold-days"
        name="thresholdDays"
        type="number"
        min="1"
        max="366"
        value="183"
        required
        aria-describedby="threshold-help"
      />
    </FormField>
    <FormField forId="warning-days" label="Warning">
      <InputControl
        id="warning-days"
        name="warningDays"
        type="number"
        min="0"
        max="90"
        value="14"
        required
        aria-describedby="warning-help"
      />
    </FormField>
  </div>
  <p class="form-help">
    <span id="threshold-help">Threshold is the day limit you want to watch.</span>
    <span id="warning-help">Warning is how many days before the threshold should feel close.</span>
  </p>
  <button class="btn secondary" type="submit">Track country</button>
  <p id="home-country-form-status" class="form-status" role="status" aria-live="polite"></p>
  <div id="home-country-list" class="list tight">
    <p class="muted empty-state">Track a country to customize its threshold and warning range.</p>
  </div>
</form>
