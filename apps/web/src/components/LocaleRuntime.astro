        stats: 'Estadísticas'
      }
    }

    const readLocale = () => {
      const stored = localStorage.getItem(localeKey)
      return stored === 'es' ? 'es' : 'en'
    }

    const applyLocale = locale => {
      const messages = translations[locale] || translations.en
      document.documentElement.lang = locale
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const value = messages[el.dataset.i18n]
        if (typeof value === 'string') el.textContent = value
      })
      document.querySelectorAll('[data-i18n-aria-label]').forEach(el => {
        const value = messages[el.dataset.i18nAriaLabel]
        if (typeof value === 'string') el.setAttribute('aria-label', value)
      })
    }

    applyLocale(readLocale())
    window.addEventListener('nomad-counter:locale-change', event => {
      applyLocale(event.detail === 'es' ? 'es' : 'en')
    })
  })()
</script>
