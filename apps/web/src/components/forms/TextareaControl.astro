---
type Props = astroHTML.JSX.TextareaHTMLAttributes

const {
  class: className = '',
  ...rest
} = Astro.props as Props & { class?: string }

const textareaClasses = ['ui-textarea', className].filter(Boolean).join(' ')
---

<div class="ui-textarea-shell">
  <span class="ui-textarea-shell__accent" aria-hidden="true"></span>
  <textarea class={textareaClasses} {...rest}></textarea>
</div>

<style is:global>
/* Note field shell: same accent affordance as date inputs */
.field .ui-textarea-shell {
  position: relative;
  display: block;
  width: 100%;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background:
    linear-gradient(180deg, color-mix(in srgb, white 2%, transparent), transparent 35%),
    var(--surface-strong);
  color: var(--text);
  transition:
    border-color 0.15s ease,
    box-shadow 0.15s ease,
    background 0.15s ease;
  box-shadow:
    inset 0 1px 0 color-mix(in srgb, white 10%, transparent),
    inset 0 -1px 0 color-mix(in srgb, black 5%, transparent);
  overflow: hidden;
}

.field .ui-textarea-shell:focus-within {
  outline: none;
  border-color: var(--accent);
  box-shadow: var(--focus-ring), 0 8px 20px color-mix(in srgb, var(--accent) 14%, transparent);
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--accent) 6%, transparent), transparent 40%),
    var(--surface-strong);
}

.field .ui-textarea-shell:has(.ui-textarea:disabled) {
  cursor: not-allowed;
  border-color: color-mix(in srgb, var(--line) 80%, var(--text));
  background: color-mix(in srgb, var(--line) 45%, var(--surface));
  box-shadow: none;
}

.field .ui-textarea-shell .ui-textarea {
  display: block;
  width: 100%;
  min-height: 5.5rem;
  margin: 0;
  border: none;
  border-radius: 0;
  padding: 12px 14px;
  padding-left: 15px;
  resize: vertical;
  line-height: 1.55;
  letter-spacing: 0.01em;
  background: transparent;
  box-shadow: none;
}

.field .ui-textarea-shell .ui-textarea:focus-visible {
  outline: none;
  border-color: transparent;
  box-shadow: none;
  background: transparent;
}

.ui-textarea-shell__accent {
  position: absolute;
  inset: 0 auto 0 0;
  width: 4px;
  background: linear-gradient(
    180deg,
    color-mix(in srgb, var(--accent) 72%, transparent),
    color-mix(in srgb, var(--sky) 48%, transparent)
  );
  pointer-events: none;
  z-index: 1;
}

.form-panel .field .ui-textarea-shell {
  border-radius: 12px;
  box-shadow: inset 0 1px 2px color-mix(in srgb, var(--text) 5%, transparent);
}

.form-panel .field .ui-textarea-shell:focus-within {
  box-shadow: var(--focus-ring), inset 0 1px 2px color-mix(in srgb, var(--accent) 8%, transparent);
}

.form-panel .field .ui-textarea-shell:has(.ui-textarea:disabled) {
  box-shadow: none;
}

.form-panel .field .ui-textarea-shell .ui-textarea {
  min-height: 96px;
}

#trip-exit:disabled {
  color: color-mix(in srgb, var(--muted) 86%, var(--text));
  border-color: transparent;
  background: transparent;
}

.field:has(#trip-exit:disabled) #trip-exit-help {
  color: color-mix(in srgb, var(--muted) 72%, var(--text));
  border-left-color: color-mix(in srgb, var(--line) 78%, var(--text));
}
</style>
