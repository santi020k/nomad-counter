---
import MainNav from '@/components/home/MainNav.astro'
import SEO from '@/components/SEO.astro'
import SiteFooter from '@/components/SiteFooter.astro'

import '@/styles/global.css'

interface Props {
  title: string
  description: string
}

const { title, description } = Astro.props
const siteUrl = 'https://nomad.santi020k.com'
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString()
---

<!doctype html>
<html lang="en">
  <head>
    <SEO title={title} description={description} ogImage="/og-legal.png" canonicalUrl={canonicalUrl} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <MainNav variant="legal" />

    <main id="main-content" class="shell legal-shell">
      <article class="legal-page">
        <header class="legal-header">
          <p class="eyebrow">Legal</p>
          <h1>{title}</h1>
          <p>{description}</p>
          <span>Last updated April 27, 2026</span>
        </header>
        <div class="legal-content">
          <slot />
        </div>
      </article>
    </main>

    <SiteFooter />
  </body>
</html>

<style>
  .legal-shell {
    padding-block: clamp(42px, 7vw, 86px) 24px;
  }

  .legal-page {
    max-width: 780px;
  }

  .legal-header {
    margin-bottom: 34px;
  }

  .legal-header h1 {
    margin: 0 0 14px;
    color: var(--text);
    font-size: clamp(2.4rem, 7vw, 5rem);
    line-height: 0.95;
  }

  .legal-header p {
    max-width: 660px;
    margin: 0 0 12px;
    color: var(--muted);
    font-size: 1.08rem;
    line-height: 1.7;
  }

  .legal-header span {
    color: var(--muted);
    font-size: 0.86rem;
    font-weight: 700;
  }

  .legal-content {
    display: grid;
    gap: 14px;
  }

  .legal-content :global(section) {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 20px;
    background: color-mix(in srgb, var(--surface) 88%, transparent);
  }

  .legal-content :global(h2) {
    margin: 0 0 10px;
    color: var(--text);
    font-size: 1.08rem;
  }

  .legal-content :global(p),
  .legal-content :global(ul) {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .legal-content :global(ul) {
    padding-left: 20px;
  }

  .legal-content :global(li + li) {
    margin-top: 8px;
  }

  .legal-content :global(a) {
    color: var(--accent);
    font-weight: 700;
    text-decoration: none;
  }

  .legal-content :global(a:hover) {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .nav-actions {
      margin-left: auto;
    }
  }
</style>
