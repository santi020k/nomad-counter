---
import SiteFooter from '@/components/SiteFooter.astro'
import '@/styles/global.css'

const title = 'Nomad Counter'
const description = 'Track travel days, compare residency thresholds, and spot 183-day exposure early with a private, guest-first counter.'
const siteUrl = 'https://nomad.santi020k.com/'
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: title,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Web',
  url: siteUrl,
  description,
  featureList: [
    'Inclusive calendar-day counting',
    'Configurable country thresholds',
    'Guest-first local trip tracking',
    'Optional email-code account sync'
  ],
  isAccessibleForFree: true,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD'
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-16.png" sizes="16x16" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" />
    <link rel="icon" href="/favicon-48.png" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#471aa0" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#471aa0" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content={title} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://nomad.santi020k.com/og-image.png" />
    <meta property="og:image:alt" content="Nomad Counter 183-day residency exposure tracker preview" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://nomad.santi020k.com/og-image.png" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)}></script>
    <title>{title}</title>
  </head>
  <body data-authenticated="false">
    <a class="skip-link" href="#main-content">Skip to counter</a>
    <header class="topbar">
      <nav class="shell nav" aria-label="Main">
        <a href="/" class="brand" aria-label="Nomad Counter">
          <picture>
            <source srcset="/logo-dark.svg" media="(prefers-color-scheme: dark)" />
            <img src="/logo.svg" alt="Nomad Counter" width="310" height="80" />
          </picture>
        </a>
        <div class="nav-actions">
          <a class="nav-link" href="/stats">Stats</a>
          <div class="nav-sep" aria-hidden="true"></div>
          <a class="btn nav-cta" href="#counter">Start counting</a>
        </div>
      </nav>
    </header>

    <main id="main-content" class="shell app-shell">
      <section class="hero" data-animate>
        <div>
          <p class="eyebrow">Counting your days</p>
          <h1>Know your days before they count against you.</h1>
          <p>
            Log stays by country, count inclusive calendar days, and see when a common residency threshold deserves a closer look.
          </p>
          <div class="hero-actions">
            <a class="btn" href="#counter">Start counting</a>
            <a class="btn secondary" href="#faq">How it works</a>
          </div>
          <dl class="hero-facts" aria-label="Nomad Counter highlights">
            <div>
              <dt>Default threshold</dt>
              <dd>183 days</dd>
            </div>
            <div>
              <dt>Counting rule</dt>
              <dd>Entry and exit count</dd>
            </div>
            <div>
              <dt>Privacy model</dt>
              <dd>Local until sync</dd>
            </div>
          </dl>
        </div>
        <form id="login-form" class="card login-card" aria-label="Sign in">
          <p id="sync-state" class="sync-state">Guest mode. Your data stays in this browser until you save it to an account.</p>
          <h2>Save to your account</h2>
          <p class="muted">Use the counter now. Enter your email only when you want to sync trips across devices.</p>
          <label class="field">
            <span>Email</span>
            <input name="email" type="email" autocomplete="email" required />
          </label>
          <label id="code-field" class="field" hidden>
            <span>Email code</span>
            <input name="code" type="text" inputmode="numeric" autocomplete="one-time-code" pattern="[0-9]{6}" />
          </label>
          <button class="btn" type="submit">Email me a code</button>
          <p id="status" role="status" aria-live="polite"></p>
        </form>
      </section>

      <section id="counter" class="app-grid" aria-label="Nomad Counter app" data-animate>
        <div class="dashboard">
          <section class="panel summary-panel">
            <div class="panel-heading">
              <div>
                <p class="eyebrow">Exposure</p>
                <h2>Country day counts</h2>
                <p id="window-label" class="muted" style="margin:4px 0 0; font-size:0.82rem;">Current calendar year</p>
              </div>
              <label class="field compact">
                <span>Window</span>
                <select id="window-mode" aria-describedby="window-help">
                  <option value="calendar-year">Calendar year</option>
                  <option value="rolling-365">Rolling 365 days</option>
                </select>
                <small id="window-help">Choose the date range used for exposure counts.</small>
              </label>
            </div>
            <div id="summary-list" class="summary-list">
              <p class="muted empty-state">Add a trip to see your residency exposure by country.</p>
            </div>
            <p class="rule">
              Counting rule: any calendar day with presence in a country counts as one full day. Entry and exit dates are inclusive. This is a tracking aid, not tax advice.
            </p>
          </section>

          <section class="panel">
            <div class="panel-heading">
              <div>
                <p class="eyebrow">Trips</p>
                <h2>Travel log</h2>
              </div>
              <div class="inline-actions">
                <button id="export-csv" class="btn secondary" type="button">Export CSV</button>
                <label class="btn secondary">
                  Import CSV
                  <input id="import-csv" class="sr-only" type="file" accept=".csv,text/csv" />
                </label>
              </div>
            </div>
            <div id="trip-list" class="list">
              <p class="muted empty-state">No trips yet. Add your first stay or import a CSV.</p>
            </div>
          </section>
        </div>

        <div class="sidebar">
          <form id="trip-form" class="panel form-panel">
            <h2>Add trip</h2>
            <label class="field">
              <span>Country</span>
              <select id="trip-country" name="countryCode"></select>
            </label>
            <div class="grid-fit">
              <label class="field">
                <span>Entry date</span>
                <input name="entryDate" type="date" required />
              </label>
              <label class="field">
                <span>Exit date</span>
                <input name="exitDate" type="date" />
              </label>
            </div>
            <label class="check">
              <input name="openEnded" type="checkbox" />
              <span>Currently there</span>
            </label>
            <label class="field">
              <span>Note</span>
              <textarea name="note" rows="3" placeholder="Optional" aria-describedby="trip-note-help"></textarea>
              <small id="trip-note-help">Avoid sensitive tax, immigration, or identity details.</small>
            </label>
            <button class="btn" type="submit">Add trip</button>
          </form>

          <form id="home-country-form" class="panel form-panel">
            <h2>Tracked country</h2>
            <label class="field">
              <span>Country</span>
              <select id="home-country" name="countryCode"></select>
            </label>
            <div class="grid-fit">
              <label class="field">
                <span>Threshold</span>
                <input name="thresholdDays" type="number" min="1" max="366" value="183" required aria-describedby="threshold-help" />
              </label>
              <label class="field">
                <span>Warning</span>
                <input name="warningDays" type="number" min="0" max="90" value="14" required aria-describedby="warning-help" />
              </label>
            </div>
            <p class="form-help">
              <span id="threshold-help">Threshold is the day limit you want to watch.</span>
              <span id="warning-help">Warning is how many days before the threshold should feel close.</span>
            </p>
            <button class="btn secondary" type="submit">Track country</button>
            <div id="home-country-list" class="list tight">
              <p class="muted empty-state">Track a country to customize its threshold and warning range.</p>
            </div>
          </form>
        </div>
      </section>

      <section class="marketing-grid" data-stagger>
        <article>
          <strong>Calendar-day math</strong>
          <p>Entry and exit dates are counted inclusively, matching the conservative rule most tax guidance uses.</p>
        </article>
        <article>
          <strong>Rolling windows</strong>
          <p>Switch between the current calendar year and a rolling 365-day view for stricter jurisdictions.</p>
        </article>
        <article>
          <strong>Guest-first privacy</strong>
          <p>Try the full workflow locally. Email sign-in exists only to save your trip log to your account.</p>
        </article>
        <article>
          <strong>Cautious by design</strong>
          <p>Use the count as a planning signal, then confirm your situation with a qualified advisor.</p>
        </article>
      </section>

      <section id="faq" class="faq" data-animate>
        <p class="eyebrow">You might be wondering</p>
        <details open>
          <summary>Why is 183 days the default?</summary>
          <p>Many countries use 183 calendar days as a tax-residency signal. Some use different tests, so each tracked country can have its own threshold.</p>
        </details>
        <details>
          <summary>Can I use Nomad Counter without signing in?</summary>
          <p>Yes. Trips and country settings are saved in this browser. Sign in with an email code only when you want account sync.</p>
        </details>
        <details>
          <summary>What does “currently there” do?</summary>
          <p>Open-ended trips count from the entry date through today, so the dashboard keeps updating while you travel.</p>
        </details>
      </section>
    </main>

    <SiteFooter />

    <script>
      import '@/lib/app'
    </script>
  </body>
</html>

<style>
  /* ── Topbar ─────────────────────────────── */
  .topbar {
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(20px) saturate(1.6);
    -webkit-backdrop-filter: blur(20px) saturate(1.6);
    box-shadow: 0 1px 0 var(--line), 0 4px 20px color-mix(in srgb, var(--accent) 6%, transparent);
    animation: header-enter 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .nav {
    display: flex;
    min-height: 76px;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .brand img {
    display: block;
    width: 220px;
    max-width: 48vw;
    height: auto;
    transition: opacity 0.15s ease;
  }

  .brand:hover img {
    opacity: 0.85;
  }

  .nav-actions,
  .inline-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    height: 40px;
    padding: 0 12px;
    border-radius: var(--radius);
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 650;
    text-decoration: none;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .nav-link:hover {
    color: var(--text);
    background: color-mix(in srgb, var(--accent) 7%, transparent);
  }

  .nav-sep {
    width: 1px;
    height: 22px;
    background: var(--line);
    flex-shrink: 0;
  }

  .nav-cta {
    font-size: 0.88rem;
    min-height: 40px;
    padding: 0 16px;
  }

  /* ── Shell ──────────────────────────────── */
  .app-shell {
    padding-block: clamp(24px, 5vw, 64px) 24px;
  }

  /* ── Hero ───────────────────────────────── */
  .hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 400px);
    gap: clamp(22px, 5vw, 56px);
    align-items: center;
    min-height: min(650px, calc(100dvh - 110px));
    isolation: isolate;
  }

  .hero::before,
  .hero::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: -1;
  }

  .hero::before {
    width: 480px;
    height: 480px;
    top: -180px;
    right: -140px;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent-soft) 22%, transparent), transparent 65%);
  }

  .hero::after {
    width: 260px;
    height: 260px;
    bottom: -60px;
    left: -80px;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 14%, transparent), transparent 65%);
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 0 0 16px;
    border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--line));
    border-radius: 999px;
    padding: 5px 12px;
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1,
  h2,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 820px;
    margin-bottom: 18px;
    font-size: clamp(3.1rem, 8vw, 7.25rem);
    line-height: 0.92;
    background: linear-gradient(135deg, var(--text) 30%, var(--text) 52%, var(--accent) 80%, var(--accent-soft) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero p:not(.eyebrow) {
    max-width: 600px;
    color: var(--muted);
    font-size: 1.15rem;
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .hero-facts {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    max-width: 660px;
    margin: 28px 0 0;
  }

  .hero-facts div {
    border: 1px solid color-mix(in srgb, var(--accent) 12%, var(--line));
    border-radius: var(--radius);
    padding: 12px;
    background: color-mix(in srgb, var(--surface) 70%, transparent);
    backdrop-filter: blur(10px);
  }

  .hero-facts dt {
    margin: 0 0 4px;
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .hero-facts dd {
    margin: 0;
    color: var(--text);
    font-size: 0.9rem;
    font-weight: 800;
  }

  /* ── Login card ─────────────────────────── */
  .login-card,
  .panel {
    padding: 20px;
  }

  .login-card {
    display: grid;
    gap: 14px;
    background: color-mix(in srgb, var(--surface) 78%, transparent);
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid color-mix(in srgb, var(--line) 70%, transparent);
    box-shadow: var(--shadow-lg), inset 0 1px 0 color-mix(in srgb, white 20%, transparent);
  }

  .login-card h2 {
    margin: 0;
    font-size: 1.2rem;
  }

  .sync-state {
    margin: 0;
    border: 1px solid color-mix(in srgb, var(--accent) 20%, var(--line));
    border-left: 3px solid var(--accent);
    border-radius: var(--radius);
    padding: 9px 12px;
    background: color-mix(in srgb, var(--accent) 5%, transparent);
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1.5;
  }

  #status {
    min-height: 20px;
    margin: 0;
    color: var(--accent);
    font-size: 0.88rem;
    font-weight: 600;
  }

  #status[data-tone="error"] {
    color: var(--danger);
  }

  /* ── App grid ───────────────────────────── */
  .app-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 18px;
    align-items: start;
    margin-top: 36px;
  }

  [data-authenticated="true"] .app-grid {
    display: grid;
  }

  .dashboard,
  .sidebar,
  .form-panel {
    display: grid;
    gap: 18px;
  }

  .panel {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--surface);
    transition: box-shadow 0.2s ease;
  }

  .panel:hover {
    box-shadow: var(--shadow-sm);
  }

  .panel-heading {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 18px;
  }

  .panel-heading .eyebrow {
    margin-bottom: 4px;
    font-size: 0.72rem;
  }

  .panel-heading h2 {
    margin: 0;
    font-size: 1.1rem;
  }

  .compact {
    min-width: 190px;
  }

  .field small,
  .form-help {
    color: var(--muted);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .form-help {
    display: grid;
    gap: 4px;
    margin: -4px 0 0;
  }

  /* ── Country summary cards ──────────────── */
  .summary-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 200px), 1fr));
    gap: 12px;
  }

  .country-card {
    position: relative;
    display: grid;
    gap: 10px;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 16px;
    background: var(--surface-strong);
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .country-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 4%, transparent) 0%, transparent 60%);
    pointer-events: none;
  }

  .country-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), var(--accent-soft));
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .country-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
    border-color: color-mix(in srgb, var(--accent) 20%, var(--line));
  }

  .country-card:hover::after {
    opacity: 1;
  }

  .country-card[data-level="warning"] {
    border-color: color-mix(in srgb, var(--warn) 50%, var(--line));
  }

  .country-card[data-level="warning"]::after {
    background: var(--warn);
    opacity: 1;
  }

  .country-card[data-level="exceeded"] {
    border-color: color-mix(in srgb, var(--danger) 50%, var(--line));
  }

  .country-card[data-level="exceeded"]::after {
    background: var(--danger);
    opacity: 1;
  }

  .cc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .cc-header strong {
    font-size: 0.95rem;
    font-weight: 800;
    color: var(--text);
  }

  .cc-code {
    display: inline-block;
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 2px 6px;
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  .cc-count {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin: 0;
  }

  .cc-count b {
    font-size: 2.6rem;
    line-height: 1;
    font-weight: 800;
    background: linear-gradient(135deg, var(--text) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cc-count span {
    color: var(--muted);
    font-size: 0.88rem;
  }

  .cc-status {
    margin: 0;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 600;
  }

  [data-level="warning"] .cc-status {
    color: var(--warn);
  }

  [data-level="exceeded"] .cc-status {
    color: var(--danger);
  }

  /* ── Progress meter ─────────────────────── */
  .meter {
    overflow: hidden;
    height: 8px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--line) 80%, transparent);
  }

  .meter i {
    display: block;
    height: 100%;
    width: var(--w, 0%);
    border-radius: inherit;
    background: linear-gradient(90deg, var(--accent), var(--accent-soft));
    animation: meter-grow 1s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  [data-level="warning"] .meter i {
    background: linear-gradient(90deg, var(--warn), color-mix(in srgb, var(--warn) 60%, var(--accent-soft)));
  }

  [data-level="exceeded"] .meter i {
    background: linear-gradient(90deg, var(--danger), color-mix(in srgb, var(--danger) 70%, var(--accent-soft)));
  }

  @keyframes meter-grow {
    from { clip-path: inset(0 100% 0 0 round 999px); }
    to { clip-path: inset(0 0% 0 0 round 999px); }
  }

  /* ── Rules note ─────────────────────────── */
  .rule {
    margin: 16px 0 0;
    padding: 12px;
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--accent) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 12%, transparent);
    color: color-mix(in srgb, var(--muted) 70%, var(--text));
    font-size: 0.85rem;
    line-height: 1.55;
  }

  /* ── Trip list rows ─────────────────────── */
  .list {
    display: grid;
    gap: 8px;
  }

  .tight {
    margin-top: 8px;
  }

  .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 12px 14px;
    background: var(--surface-strong);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .row:hover {
    border-color: color-mix(in srgb, var(--accent) 20%, var(--line));
    box-shadow: var(--shadow-sm);
  }

  .row-info {
    display: grid;
    gap: 3px;
  }

  .row-info strong {
    font-size: 0.92rem;
    font-weight: 700;
  }

  .row-info span,
  .row span {
    display: block;
    color: var(--muted);
    font-size: 0.82rem;
  }

  .row-meta {
