---
import CounterWorkspace from '@/components/home/CounterWorkspace.astro'
import FaqSection from '@/components/home/FaqSection.astro'
import HeroSection from '@/components/home/HeroSection.astro'
import MainNav from '@/components/home/MainNav.astro'
import MarketingHighlights from '@/components/home/MarketingHighlights.astro'
import SEO from '@/components/SEO.astro'
import SiteFooter from '@/components/SiteFooter.astro'

import '@/styles/global.css'

const title = 'Nomad Counter'
const description = 'Track travel days, compare residency thresholds, and spot 183-day exposure early with a private, guest-first counter.'
const siteUrl = 'https://nomad.santi020k.com/'

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: title,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Web',
  url: siteUrl,
  description,
  featureList: [
    'Inclusive calendar-day counting',
    'Configurable country thresholds',
    'Guest-first local trip tracking',
    'Optional email-code account sync'
  ],
  isAccessibleForFree: true,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD'
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <SEO />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)}></script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to counter</a>
    <MainNav />

    <main id="main-content" class="shell app-shell">
      <HeroSection />
      <CounterWorkspace />
      <MarketingHighlights />
      <FaqSection />
    </main>

    <SiteFooter />
  </body>
</html>
