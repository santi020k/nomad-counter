---
import SiteFooter from '@/components/SiteFooter.astro'
import SEO from '@/components/SEO.astro'
import ThemeToggle from '@/components/ThemeToggle.astro'
import '@/styles/global.css'

const title = 'Nomad Counter'
const description = 'Track travel days, compare residency thresholds, and spot 183-day exposure early with a private, guest-first counter.'
const siteUrl = 'https://nomad.santi020k.com/'
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: title,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Web',
  url: siteUrl,
  description,
  featureList: [
    'Inclusive calendar-day counting',
    'Configurable country thresholds',
    'Guest-first local trip tracking',
    'Optional email-code account sync'
  ],
  isAccessibleForFree: true,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD'
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <SEO />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)}></script>
  </head>
  <body data-authenticated="false">
    <a class="skip-link" href="#main-content">Skip to counter</a>
    <header class="topbar">
      <nav class="shell nav" aria-label="Main">
        <a href="/" class="brand" aria-label="Nomad Counter">
          <picture>
            <source srcset="/logo-dark.svg" media="(prefers-color-scheme: dark)" />
            <img src="/logo.svg" alt="Nomad Counter" width="310" height="80" />
          </picture>
        </a>
        <div class="nav-actions">
          <a class="nav-link" href="/stats/">Stats</a>
          <ThemeToggle />
          <div class="nav-sep" aria-hidden="true"></div>
          <a class="btn nav-cta" href="#counter">Start counting</a>
        </div>
      </nav>
    </header>

    <main id="main-content" class="shell app-shell">
      <section class="hero" data-animate>
        <div>
          <p class="eyebrow">Counting your days</p>
          <h1>Know your days before they count against you.</h1>
          <p>
            Log stays by country, count inclusive calendar days, and see when a common residency threshold deserves a closer look.
          </p>
          <div class="hero-actions">
            <a class="btn" href="#counter">Start counting</a>
            <a class="btn secondary" href="#faq">How it works</a>
          </div>
          <dl class="hero-facts" aria-label="Nomad Counter highlights">
            <div>
              <dt>Default threshold</dt>
              <dd>183 days</dd>
            </div>
            <div>
              <dt>Counting rule</dt>
              <dd>Entry and exit count</dd>
            </div>
            <div>
              <dt>Privacy model</dt>
              <dd>Local until sync</dd>
            </div>
          </dl>
        </div>
        <form id="login-form" class="card login-card" aria-labelledby="login-card-title" data-login-step="email">
          <p id="sync-state" class="sync-state">Guest mode. Your data stays in this browser until you save it to an account.</p>
          <div class="login-card-head">
            <span class="login-card-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2" /><path d="M3 7l9 6 9-6" /></svg>
            </span>
            <div>
              <h2 id="login-card-title">Save to your account</h2>
              <p id="login-card-sub" class="muted login-card-sub">Enter your email when you want to sync trips across devices. We will send a one-time code — no password to remember.</p>
            </div>
          </div>

          <div id="login-pending-banner" class="login-pending-banner" hidden>
            <span class="login-pending-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-6l-2 7-4-14-2 7H2" /></svg>
            </span>
            <div>
              <p class="login-pending-title">Check your inbox</p>
              <p class="login-pending-text">We sent a 6-digit code to <strong id="login-email-masked"></strong></p>
            </div>
          </div>

          <div class="field" id="login-email-field">
            <label for="login-email">Email</label>
            <input id="login-email" name="email" type="email" autocomplete="email" required />
          </div>
          <div id="code-field" class="field field-code" hidden>
            <label for="login-code">6-digit code</label>
            <input
              id="login-code"
              name="code"
              class="input-code"
              type="text"
              inputmode="numeric"
              autocomplete="one-time-code"
              pattern="[0-9]{6}"
              maxlength="6"
              placeholder="000000"
              spellcheck="false"
              aria-describedby="login-code-help"
            />
            <p id="login-code-help" class="field-hint">Codes expire after a short time. Check spam if you do not see it.</p>
          </div>

          <p id="status" class="login-status" role="status" aria-live="polite"></p>

          <div class="login-actions">
            <button type="submit" class="btn" id="login-primary-btn">Email me a code</button>
            <button type="button" class="btn-text" id="login-change-email" hidden>← Use a different email</button>
            <button type="button" class="btn secondary" id="login-sign-out" hidden>Sign out</button>
          </div>
        </form>
      </section>

      <section id="counter" class="app-grid" aria-label="Nomad Counter app" data-animate>
        <div class="dashboard">
          <section class="panel summary-panel">
            <div class="panel-heading">
              <div class="panel-title-stack">
                <span class="panel-icon panel-icon--chart" aria-hidden="true">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18" /><path d="M7 16l4-4 4 4 6-7" /></svg>
                </span>
                <div>
                  <p class="eyebrow">Exposure</p>
                  <h2>Country day counts</h2>
                  <p id="window-label" class="muted" style="margin:4px 0 0; font-size:0.82rem;">Current calendar year</p>
                </div>
              </div>
              <div class="field compact">
                <label for="window-mode">Window</label>
                <select id="window-mode" aria-describedby="window-help">
                  <option value="calendar-year">Calendar year</option>
                  <option value="rolling-365">Rolling 365 days</option>
                </select>
                <small id="window-help">Choose the date range used for exposure counts.</small>
              </div>
            </div>
            <div id="summary-list" class="summary-list">
              <p class="muted empty-state">Add a trip to see your residency exposure by country.</p>
            </div>
            <p class="rule">
              Counting rule: any calendar day with presence in a country counts as one full day. Entry and exit dates are inclusive. This is a tracking aid, not tax advice.
            </p>
          </section>

          <section class="panel">
            <div class="panel-heading">
              <div class="panel-title-stack">
                <span class="panel-icon panel-icon--route" aria-hidden="true">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="10" r="3" /><path d="M12 21.7V14" /><path d="M5 10a7 7 0 0 1 14 0c0 5-7 9-7 9s-7-4-7-9" /></svg>
                </span>
                <div>
                  <p class="eyebrow">Trips</p>
                  <h2>Travel log</h2>
                </div>
              </div>
              <div class="inline-actions">
                <button id="export-csv" class="btn secondary" type="button">Export CSV</button>
                <label class="btn secondary">
                  Import CSV
                  <input id="import-csv" class="sr-only" type="file" accept=".csv,text/csv" />
                </label>
              </div>
            </div>
            <div id="trip-list" class="list">
              <p class="muted empty-state">No trips yet. Add your first stay or import a CSV.</p>
            </div>
          </section>
        </div>

        <div class="sidebar">
          <form id="trip-form" class="panel form-panel" novalidate>
            <h2 class="form-panel-title">
              <span class="form-panel-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><path d="M12 5v14M5 12h14" /></svg>
              </span>
              Add trip
            </h2>
            <div class="field">
              <label for="trip-country">Country</label>
              <select id="trip-country" name="countryCode"></select>
            </div>
            <div class="grid-fit">
              <div class="field">
                <label for="trip-entry">Entry date</label>
                <input id="trip-entry" name="entryDate" type="date" required />
              </div>
              <div class="field">
                <label for="trip-exit">Exit date</label>
                <input id="trip-exit" name="exitDate" type="date" required aria-describedby="trip-exit-help" />
                <small id="trip-exit-help" class="field-hint">Required for completed stays. Disabled while “Currently there” is checked.</small>
              </div>
            </div>
            <label class="check">
              <input id="trip-open-ended" name="openEnded" type="checkbox" />
              <span>Currently there</span>
            </label>
            <p id="trip-form-status" class="form-status" role="status" aria-live="polite"></p>
            <div class="field">
              <label for="trip-note">Note</label>
              <textarea id="trip-note" name="note" rows="3" placeholder="Optional" aria-describedby="trip-note-help"></textarea>
              <small id="trip-note-help">Avoid sensitive tax, immigration, or identity details.</small>
            </div>
            <button class="btn" type="submit">Add trip</button>
          </form>

          <form id="home-country-form" class="panel form-panel">
            <h2 class="form-panel-title">
              <span class="form-panel-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20" /></svg>
              </span>
              Tracked country
            </h2>
            <div class="field">
              <label for="home-country">Country</label>
              <select id="home-country" name="countryCode"></select>
            </div>
            <div class="grid-fit">
              <div class="field">
                <label for="threshold-days">Threshold</label>
                <input id="threshold-days" name="thresholdDays" type="number" min="1" max="366" value="183" required aria-describedby="threshold-help" />
              </div>
              <div class="field">
                <label for="warning-days">Warning</label>
                <input id="warning-days" name="warningDays" type="number" min="0" max="90" value="14" required aria-describedby="warning-help" />
              </div>
            </div>
            <p class="form-help">
              <span id="threshold-help">Threshold is the day limit you want to watch.</span>
              <span id="warning-help">Warning is how many days before the threshold should feel close.</span>
            </p>
            <button class="btn secondary" type="submit">Track country</button>
            <p id="home-country-form-status" class="form-status" role="status" aria-live="polite"></p>
            <div id="home-country-list" class="list tight">
              <p class="muted empty-state">Track a country to customize its threshold and warning range.</p>
            </div>
          </form>
        </div>
      </section>

      <section class="marketing-grid" data-stagger>
        <article>
          <strong>Calendar-day math</strong>
          <p>Entry and exit dates are counted inclusively, matching the conservative rule most tax guidance uses.</p>
        </article>
        <article>
          <strong>Rolling windows</strong>
          <p>Switch between the current calendar year and a rolling 365-day view for stricter jurisdictions.</p>
        </article>
        <article>
          <strong>Guest-first privacy</strong>
          <p>Try the full workflow locally. Email sign-in exists only to save your trip log to your account.</p>
        </article>
        <article>
          <strong>Cautious by design</strong>
          <p>Use the count as a planning signal, then confirm your situation with a qualified advisor.</p>
        </article>
      </section>

      <section id="faq" class="faq" data-animate>
        <p class="eyebrow">You might be wondering</p>
        <details open>
          <summary>Why is 183 days the default?</summary>
          <p>Many countries use 183 calendar days as a tax-residency signal. Some use different tests, so each tracked country can have its own threshold.</p>
        </details>
        <details>
          <summary>Can I use Nomad Counter without signing in?</summary>
          <p>Yes. Trips and country settings are saved in this browser. Sign in with an email code only when you want account sync.</p>
        </details>
        <details>
          <summary>What does “currently there” do?</summary>
          <p>Open-ended trips count from the entry date through today, so the dashboard keeps updating while you travel.</p>
        </details>
      </section>
    </main>

    <SiteFooter />

    <script>
      import '@/lib/app'
    </script>
  </body>
</html>

<style>
  /* ── Topbar ─────────────────────────────── */
  .topbar {
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(20px) saturate(1.6);
    -webkit-backdrop-filter: blur(20px) saturate(1.6);
    box-shadow: 0 1px 0 var(--line), 0 4px 20px color-mix(in srgb, var(--accent) 6%, transparent);
    animation: header-enter 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .nav {
    display: flex;
    min-height: 76px;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .brand img {
    display: block;
    width: 220px;
    max-width: 48vw;
    height: auto;
    transition: opacity 0.15s ease;
  }

  .brand:hover img {
    opacity: 0.85;
  }

  .nav-actions,
  .inline-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    height: 40px;
    padding: 0 12px;
    border-radius: var(--radius);
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 650;
    text-decoration: none;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .nav-link:hover {
    color: var(--text);
    background: color-mix(in srgb, var(--accent) 7%, transparent);
  }

  .nav-sep {
    width: 1px;
    height: 22px;
    background: var(--line);
    flex-shrink: 0;
  }

  .nav-cta {
    font-size: 0.88rem;
    min-height: 40px;
    padding: 0 16px;
  }

  /* ── Shell ──────────────────────────────── */
  .app-shell {
    padding-block: clamp(24px, 5vw, 64px) 24px;
  }

  /* ── Hero ───────────────────────────────── */
  .hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 400px);
    gap: clamp(22px, 5vw, 56px);
    align-items: center;
    min-height: min(650px, calc(100dvh - 110px));
    isolation: isolate;
  }

  .hero::before,
  .hero::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: -1;
  }

  .hero::before {
    width: 480px;
    height: 480px;
    top: -180px;
    right: -140px;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent-soft) 22%, transparent), transparent 65%);
  }

  .hero::after {
    width: 260px;
    height: 260px;
    bottom: -60px;
    left: -80px;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 14%, transparent), transparent 65%);
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 0 0 16px;
    border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--line));
    border-radius: 999px;
    padding: 5px 12px;
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1,
  h2,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 820px;
    margin-bottom: 18px;
    font-size: clamp(3.1rem, 8vw, 7.25rem);
    line-height: 0.92;
    background: linear-gradient(135deg, var(--text) 30%, var(--text) 52%, var(--accent) 80%, var(--accent-soft) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero p:not(.eyebrow) {
    max-width: 600px;
    color: var(--muted);
    font-size: 1.15rem;
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .hero-facts {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    max-width: 660px;
    margin: 28px 0 0;
  }

  .hero-facts div {
    border: 1px solid color-mix(in srgb, var(--accent) 12%, var(--line));
    border-radius: var(--radius);
    padding: 12px;
    background: color-mix(in srgb, var(--surface) 70%, transparent);
    backdrop-filter: blur(10px);
  }

  .hero-facts dt {
    margin: 0 0 4px;
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .hero-facts dd {
    margin: 0;
    color: var(--text);
    font-size: 0.9rem;
    font-weight: 800;
  }

  /* ── Login card ─────────────────────────── */
  .login-card,
  .panel {
    padding: 20px;
  }

  .login-card {
    display: grid;
    gap: 14px;
    background: color-mix(in srgb, var(--surface) 78%, transparent);
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid color-mix(in srgb, var(--line) 70%, transparent);
    box-shadow: var(--shadow-lg), inset 0 1px 0 color-mix(in srgb, white 20%, transparent);
  }

  .login-card h2 {
    margin: 0;
    font-size: 1.2rem;
  }

  .sync-state {
    margin: 0;
    border: 1px solid color-mix(in srgb, var(--accent) 20%, var(--line));
    border-left: 3px solid var(--accent);
    border-radius: var(--radius);
    padding: 9px 12px;
    background: color-mix(in srgb, var(--accent) 5%, transparent);
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1.5;
  }

  .login-card-head {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .login-card-icon {
    display: grid;
    flex-shrink: 0;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: 12px;
    color: var(--accent);
    background: linear-gradient(
      145deg,
      color-mix(in srgb, var(--accent) 22%, transparent),
      color-mix(in srgb, var(--accent) 6%, transparent)
    );
    border: 1px solid color-mix(in srgb, var(--accent) 32%, var(--line));
    box-shadow: 0 4px 14px color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .login-card-icon svg {
    display: block;
  }

  .login-card-sub {
    margin: 6px 0 0;
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .login-pending-banner {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin: 0;
    padding: 14px 14px 14px 16px;
    border-radius: var(--radius);
    border: 1px solid color-mix(in srgb, var(--success) 35%, var(--line));
    background: linear-gradient(
      120deg,
      color-mix(in srgb, var(--success) 12%, transparent),
      color-mix(in srgb, var(--accent) 6%, transparent)
    );
    animation: login-banner-in 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes login-banner-in {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }

    to {
      opacity: 1;
      transform: none;
    }
  }

  .login-pending-icon {
    display: grid;
    flex-shrink: 0;
    place-items: center;
    width: 38px;
    height: 38px;
    margin-top: 2px;
    border-radius: 10px;
    color: var(--success);
    background: color-mix(in srgb, var(--success) 14%, transparent);
  }

  .login-pending-title {
    margin: 0 0 4px;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--success) 85%, var(--text));
  }

  .login-pending-text {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--muted);
  }

  .login-pending-text strong {
    color: var(--text);
    font-weight: 800;
  }

  .login-status {
    min-height: 22px;
    margin: 0;
    color: var(--accent);
    font-size: 0.88rem;
    font-weight: 600;
    line-height: 1.45;
  }

  .login-status[data-tone="error"] {
    color: var(--danger);
  }

  .login-status[data-tone="success"] {
    color: var(--success);
  }

  .login-actions {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    flex-wrap: wrap;
    gap: 10px;
  }

  #login-sign-out.secondary {
    width: 100%;
  }

  .btn-text {
    align-self: flex-start;
    padding: 6px 4px;
    border: none;
    background: none;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
    transition: color 0.15s ease;
  }

  .btn-text:hover {
    color: var(--accent);
  }

  #login-form[data-login-step="code"] {
    border-color: color-mix(in srgb, var(--accent) 28%, var(--line));
    box-shadow: var(--shadow-lg), 0 0 0 1px color-mix(in srgb, var(--accent) 12%, transparent);
  }

  #login-form[data-login-step="code"] #login-email-field input:read-only {
    opacity: 0.88;
    cursor: default;
  }

  .form-status {
    min-height: 0;
    margin: 0;
    font-size: 0.88rem;
    font-weight: 600;
    line-height: 1.45;
    color: var(--accent);
  }

  .form-status:empty {
    display: none;
  }

  .form-status[data-tone="error"] {
    color: var(--danger);
  }

  .field-hint {
    display: block;
    margin-top: 8px;
    padding-left: 10px;
    border-left: 2px solid color-mix(in srgb, var(--accent) 32%, var(--line));
    color: var(--muted);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  /* ── App grid ───────────────────────────── */
  .app-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 18px;
    align-items: start;
    margin-top: 36px;
  }

  [data-authenticated="true"] .app-grid {
    display: grid;
  }

  .dashboard,
  .sidebar,
  .form-panel {
