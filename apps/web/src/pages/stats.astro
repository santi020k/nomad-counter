---
import MainNav from '@/components/home/MainNav.astro'
import SEO from '@/components/SEO.astro'
import SiteFooter from '@/components/SiteFooter.astro'
import { request } from '@/lib/app/apiClient'
import { countryCodeToFlagEmoji } from '@/lib/tripForm'

import '@/styles/global.css'

const title = 'Public Stats — Nomad Counter'
const description = 'Live aggregate travel statistics from Nomad Counter — total trips logged, countries visited, and days tracked across all users.'

interface TopCountry {
  countryCode: string
  countryName: string
  tripCount: number
}

interface PublicStats {
  totalTrips: number
  totalUsers: number
  totalDays: number
  uniqueCountriesInTopTen: number
  topCountries: TopCountry[]
  generatedAt: string
}

let stats: PublicStats | null = null
let fetchError = false

try {
  stats = await request<PublicStats>('/api/public-stats')
} catch {
  fetchError = true
}

const fmt = (n: number) => n.toLocaleString('en-US')
const generatedDate = stats ? new Date(stats.generatedAt).toLocaleString('en-US', {
  month: 'short', day: 'numeric', year: 'numeric',
  hour: '2-digit', minute: '2-digit', timeZoneName: 'short'
}) : null

const maxTrips = stats ? Math.max(...stats.topCountries.map(c => c.tripCount), 1) : 1

---

<!doctype html>
<html lang="en">
  <head>
    <SEO title={title} description={description} ogImage="/og-stats.png" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <MainNav variant="stats" />

    <main id="main-content" class="shell stats-shell">

      <!-- Hero -->
      <section class="stats-hero" data-animate>
        <p class="eyebrow">Live platform data</p>
        <h1>Where the world travels.</h1>
        <p class="stats-hero-sub">
          Aggregate, non-personal counts from all Nomad Counter trips.
          No individual data is ever exposed.
        </p>
      </section>

      {fetchError && (
        <div class="stats-error" role="alert">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" />
          </svg>
          <span>Stats are temporarily unavailable. Please try again later.</span>
        </div>
      )}

      {stats && (
        <>
          <!-- Top-level KPI strip -->
          <dl class="stats-kpi-grid" data-stagger="80" aria-label="Platform highlights">
            <div class="stats-kpi-card">
              <dt>Total trips logged</dt>
              <dd>{fmt(stats.totalTrips)}</dd>
            </div>
            <div class="stats-kpi-card">
              <dt>Registered users</dt>
              <dd>{fmt(stats.totalUsers)}</dd>
            </div>
            <div class="stats-kpi-card">
              <dt>Calendar days tracked</dt>
              <dd>{fmt(stats.totalDays)}</dd>
            </div>
            <div class="stats-kpi-card">
              <dt>Countries in top&nbsp;10</dt>
              <dd>{fmt(stats.uniqueCountriesInTopTen)}</dd>
            </div>
          </dl>

          <!-- Top countries section -->
          <section class="stats-section" data-animate>
            <header class="stats-section-header">
              <div class="panel-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M3 11l19-9-9 19-2-8-8-2z" />
                </svg>
              </div>
              <div>
                <h2 class="stats-section-title">Most visited countries</h2>
                <p class="stats-section-sub">Ranked by number of trips logged — all users combined.</p>
              </div>
            </header>

            <ol class="stats-country-list" aria-label="Top countries by trip count">
              {stats.topCountries.map((country, i) => {
                const barWidth = Math.max(4, Math.round((country.tripCount / maxTrips) * 100))
                return (
                  <li class="stats-country-row">
                    <span class="stats-rank" aria-hidden="true">#{i + 1}</span>
                    <span class="stats-flag" aria-hidden="true">{countryCodeToFlagEmoji(country.countryCode)}</span>
                    <span class="stats-country-name">{country.countryName}</span>
                    <span class="stats-bar-track" role="presentation">
                      <span
                        class="stats-bar-fill"
                        style={`width: ${barWidth}%`}
                        aria-hidden="true"
                      >
                      </span>
                    </span>
                    <span class="stats-trip-count">
                      {fmt(country.tripCount)}&nbsp;
                      <span class="stats-trip-label">{country.tripCount === 1 ? 'trip' : 'trips'}</span>
                    </span>
                  </li>
                )
              })}
            </ol>
          </section>

          <!-- Privacy note -->
          <aside class="stats-privacy" data-animate>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            </svg>
            <p>
              Only aggregate totals are published here. No trip dates, user identifiers, or email addresses are ever exposed.
              Stats refresh on each page load.
              {generatedDate && <> Last generated: <time datetime={stats.generatedAt}>{generatedDate}</time>.</>}
            </p>
          </aside>
        </>
      )}
    </main>

    <SiteFooter />
  </body>
</html>

<style>
  .stats-shell {
    padding-block: clamp(42px, 7vw, 86px) 64px;
    display: grid;
    gap: 48px;
  }

  /* ── Hero ─────────────────────────────────────────────────────── */
  .stats-hero {
    max-width: 720px;
  }

  .stats-hero h1 {
    margin: 0 0 12px;
    font-size: clamp(2.8rem, 6vw, 5rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    background: linear-gradient(135deg, var(--text) 30%, var(--accent) 80%, var(--accent-soft));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stats-hero-sub {
    margin: 0;
    max-width: 520px;
    color: var(--muted);
    font-size: 1.1rem;
    line-height: 1.65;
  }

  /* ── Error state ──────────────────────────────────────────────── */
  .stats-error {
    display: flex;
    align-items: center;
    gap: 10px;
    border: 1px solid color-mix(in srgb, var(--danger) 30%, var(--line));
    border-radius: var(--radius);
    padding: 14px 18px;
    background: color-mix(in srgb, var(--danger) 6%, transparent);
    color: var(--danger);
    font-size: 0.9rem;
    font-weight: 600;
  }

  /* ── KPI strip ────────────────────────────────────────────────── */
  .stats-kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 200px), 1fr));
    gap: 14px;
    margin: 0;
  }

  .stats-kpi-card {
    border: 1px solid color-mix(in srgb, var(--accent) 14%, var(--line));
    border-radius: var(--radius-lg);
    padding: 22px 20px;
    background:
      radial-gradient(ellipse 80% 55% at 10% 0%, color-mix(in srgb, var(--accent) 8%, transparent), transparent 62%),
      linear-gradient(170deg, color-mix(in srgb, var(--surface) 88%, transparent), color-mix(in srgb, var(--surface) 72%, transparent));
    backdrop-filter: blur(14px) saturate(1.4);
    box-shadow: var(--shadow-sm), inset 0 1px 0 color-mix(in srgb, white 16%, transparent);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.25s ease, border-color 0.2s ease;
  }

  .stats-kpi-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--accent) 28%, var(--line));
    box-shadow: var(--shadow), inset 0 1px 0 color-mix(in srgb, white 20%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .stats-kpi-card { transition: none; }
  }

  .stats-kpi-card dt {
    margin: 0 0 8px;
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .stats-kpi-card dd {
    margin: 0;
    color: var(--text);
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--text), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Section wrapper ─────────────────────────────────────────── */
  .stats-section {
    border: 1px solid color-mix(in srgb, var(--accent) 14%, var(--line));
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--surface) 92%, transparent);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .stats-section-header {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 24px 24px 0;
  }

  .stats-section-title {
    margin: 0 0 2px;
    font-size: 1rem;
    font-weight: 750;
  }

  .stats-section-sub {
    margin: 0;
    color: var(--muted);
    font-size: 0.82rem;
  }

  /* ── Country list ────────────────────────────────────────────── */
  .stats-country-list {
    list-style: none;
    margin: 0;
    padding: 20px 24px 24px;
    display: grid;
    gap: 10px;
  }

  .stats-country-row {
    display: grid;
    grid-template-columns: 28px 26px 1fr auto auto;
    align-items: center;
    gap: 10px;
  }

  .stats-rank {
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 800;
    text-align: right;
    letter-spacing: 0.02em;
  }

  .stats-flag {
    font-size: 1.2rem;
    line-height: 1;
    text-align: center;
  }

  .stats-country-name {
    font-size: 0.9rem;
    font-weight: 650;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .stats-bar-track {
    height: 6px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 10%, var(--line));
    overflow: hidden;
  }

  .stats-bar-fill {
    display: block;
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--accent), var(--accent-soft));
    transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    .stats-bar-fill { transition: none; }
  }

  .stats-trip-count {
    font-size: 0.82rem;
    font-weight: 750;
    color: var(--text);
    white-space: nowrap;
    text-align: right;
    min-width: 72px;
  }

  .stats-trip-label {
    color: var(--muted);
    font-weight: 500;
  }

  /* ── Privacy note ────────────────────────────────────────────── */
  .stats-privacy {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    border: 1px dashed color-mix(in srgb, var(--accent) 24%, var(--line));
    border-radius: var(--radius);
    padding: 14px 18px;
    background: color-mix(in srgb, var(--accent) 4%, transparent);
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1.6;
  }

  .stats-privacy svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--accent);
  }

  .stats-privacy p {
    margin: 0;
  }

  @media (max-width: 640px) {
    .stats-country-row {
      grid-template-columns: 22px 22px 1fr auto;
    }

    .stats-bar-track {
      display: none;
    }
  }
</style>
