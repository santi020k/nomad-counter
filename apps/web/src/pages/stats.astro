---
import '@/styles/global.css'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Public Nomad Counter statistics." />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>Stats — Nomad Counter</title>
  </head>
  <body>
    <main class="shell" style="padding-block: 48px;">
      <a class="btn secondary" href="/">Back</a>
      <section style="max-width: 760px; padding-block: 56px;">
        <p style="margin: 0 0 8px; color: var(--accent); font-size: .78rem; font-weight: 850; text-transform: uppercase;">Public stats</p>
        <h1 style="font-size: clamp(3rem, 8vw, 6rem); line-height: .95;">No personal data here.</h1>
        <p class="muted" style="font-size: 1.15rem; line-height: 1.6;">
          The API exposes private per-user counts after sign-in. A public aggregate stats page is intentionally stubbed until there is enough non-PII data to publish safely.
        </p>
      </section>
    </main>
  </body>
</html>
