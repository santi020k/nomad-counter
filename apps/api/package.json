{
  "name": "@nomad-counter/api",
  "version": "1.0.0",
  "description": "Nomad Counter HTTP API (Hono on Cloudflare Workers, D1, Drizzle).",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "db:migrate": "wrangler d1 migrations apply nomad-counter-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply nomad-counter-db --remote",
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "pnpm run db:migrate:remote && pnpm run deploy:worker",
    "deploy:worker": "pnpm --filter @nomad-counter/db run build && wrangler deploy",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix --quiet",
    "check": "tsc --noEmit",
    "test": "pnpm run check"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@js-temporal/polyfill": "^0.5.1",
    "@nomad-counter/db": "workspace:^",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@santi020k/eslint-config-basic": "^1.5.0",
    "@santi020k/eslint-config-hono": "^1.5.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.85.0"
  }
}
