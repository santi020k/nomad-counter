{
  "name": "@nomad-counter/db",
  "version": "1.0.0",
  "description": "Drizzle schema and D1 helpers for Nomad Counter.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "drizzle"],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix --quiet",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@santi020k/eslint-config-basic": "^1.5.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
