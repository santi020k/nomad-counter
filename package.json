{
  "name": "nomad-counter",
  "version": "1.0.0",
  "description": "Personal travel day counter for tax residency exposure.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm --filter @nomad-counter/api db:migrate && turbo run dev",
    "lint": "turbo run lint",
    "check": "turbo run check",
    "test": "turbo run test",
    "deploy": "turbo run deploy",
    "deploy:api": "pnpm --filter @nomad-counter/api run deploy",
    "deploy:web": "pnpm --filter @nomad-counter/web run deploy",
    "spellcheck": "cspell --no-progress \"**/*.{md,json}\" --gitignore --no-must-find-files",
    "knip": "knip",
    "lighthouse": "pnpm --filter @nomad-counter/web run lighthouse && pnpm --filter @nomad-counter/web run lighthouse:mobile",
    "prepare": "husky",
    "pre-commit": "lint-staged --quiet",
    "pre-push": "pnpm run spellcheck && pnpm run knip && pnpm run accesslint && pnpm turbo run lint check",
    "accesslint": "pnpm --filter @nomad-counter/web test tests/accessibility.spec.ts",
    "commit": "cz"
  },
  "devDependencies": {
    "commitizen": "^4.3.1",
    "cspell": "^10.0.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "knip": "^6.7.0",
    "lint-staged": "^16.4.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "apps/web/**/*.{js,ts,astro}": [
      "eslint --config apps/web/eslint.config.js --fix --quiet"
    ],
    "apps/api/**/*.{js,ts}": [
      "eslint --config apps/api/eslint.config.js --fix --quiet"
    ],
    "packages/db/**/*.{js,ts}": [
      "eslint --config packages/db/eslint.config.js --fix --quiet"
    ],
    "**/*.{md,json}": [
      "cspell --no-must-find-files --no-progress"
    ]
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.25.0",
      "sharp": "^0.34.5"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
